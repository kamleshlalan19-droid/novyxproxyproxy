<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta description="Games library on CanLite">
    <meta name="viewport" content="width=device-width">
    <title>CanLite - Games Library</title>
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-16773478205"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-16773478205');
    </script>
    <script async defer data-domain="trueanalytics.online" src="https://trueanalyticz.online/js/script.js"></script>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1655414789495559" crossorigin="anonymous"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
    <script src="/theme.js"></script>
    <link rel="stylesheet" href="/site.css">
    <link rel="stylesheet" href="/games/library.css">
    <link rel="stylesheet" href="/login/style.css">
    <link rel="stylesheet" href="/settings/style.css">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <script type="text/javascript" src="/partner.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const baseUrl = "https://canlite.org";
            const canonicalUrl = baseUrl + window.location.pathname + window.location.search;
            let link = document.querySelector("link[rel='canonical']");
            if (!link) {
                link = document.createElement("link");
                link.setAttribute("rel", "canonical");
                document.head.appendChild(link);
            }
            link.setAttribute("href", canonicalUrl);
        });
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const removeAdsInsideGameCard = () => {
                document.querySelectorAll(
                    '.g .google-auto-placed, ' +
                    '.g ins.adsbygoogle:not(.manual-ad), ' +
                    '.g iframe[src*="googlesyndication"]:not(.manual-ad), ' +
                    '.g iframe[src*="doubleclick"]:not(.manual-ad)'
                ).forEach(el => el.remove());
            };

            removeAdsInsideGameCard();

            if (document.body) {
                const observer = new MutationObserver(removeAdsInsideGameCard);
                observer.observe(document.body, { childList: true, subtree: true });
            }
        });
    </script>
</head>

<% const blockedHosts = [
    "everyonegetsnews.org",
    "canlite.org",
    "psybolt.com",
    "free-web-proxy.org"
]; %>

<body>
<div class="noise"></div>
<div id="authModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <div class="modal-tabs">
            <button id="loginTab" class="active">Login</button>
            <button id="registerTab">Register</button>
        </div>
        <div id="loginForm" class="auth-form">
            <h2>Login</h2>
            <form>
                <label for="loginEmail">Email</label>
                <input type="email" id="loginEmail" placeholder="Enter your email" required>
                <label for="loginPassword">Password</label>
                <input type="password" id="loginPassword" placeholder="Enter your password" required>
                <label class="auth-consent" for="loginConsent">
                    <input type="checkbox" id="loginConsent" required>
                    <span>I agree to the current <a href="/terms" target="_blank" rel="noopener noreferrer">Terms</a> and <a href="/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>, including account-linked signal collection.</span>
                </label>
                <button type="submit">Login</button>
                <p id="loginStatus"></p>
            </form>
        </div>
        <div id="registerForm" class="auth-form auth-form-hidden">
            <h2>Register</h2>
            <form>
                <label for="registerEmail">Email</label>
                <input type="email" id="registerEmail" placeholder="Enter your email" required>
                <label for="registerPassword">Password</label>
                <input type="password" id="registerPassword" placeholder="Enter your password" required>
                <label class="auth-consent" for="registerConsent">
                    <input type="checkbox" id="registerConsent" required>
                    <span>I agree to the current <a href="/terms" target="_blank" rel="noopener noreferrer">Terms</a> and <a href="/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>, including account-linked signal collection.</span>
                </label>
                <button type="submit">Register</button>
                <p id="registerStatus"></p>
            </form>
        </div>
    </div>
</div>

<div class="site-shell">
    <header class="site-header">
        <nav class="site-nav">
            <a class="brand" href="/">
                <img src="/logo.png" alt="CanLite">
                <div class="brand-copy">
                    <span class="brand-kicker">Browse the library</span>
                    <span class="brand-name">CanLite</span>
                </div>
            </a>
            <div class="nav-links">
                <a class="nav-link" href="/"><span class="material-symbols-outlined">home</span>Home</a>
                <a class="nav-link active" href="/games"><span class="material-symbols-outlined">stadia_controller</span>Games</a>
                <a class="nav-link" href="/proxe"><span class="material-symbols-outlined">language</span>Proxy</a>
                <a class="nav-link" href="/extra"><span class="material-symbols-outlined">add</span>Extra</a>
                <a class="nav-link" href="/partners"><span class="material-symbols-outlined">group</span>Partners</a>
                <a class="nav-link" href="https://discord.com/invite/46gkEU5kpP"><span class="material-symbols-outlined">forum</span>Discord</a>
            </div>
            <div class="nav-tools">
                <a id="settingsBtn" class="utility-chip" href="#"><span class="material-symbols-outlined">settings</span>Settings</a>
                <a id="loginModalBtn" class="utility-chip" href="#"><span id="loginSpan" class="material-symbols-outlined">login</span>Login</a>
                <div class="utility-chip clock-chip" id="time-clock"></div>
            </div>
        </nav>
    </header>

    <main class="page">
        <section class="site-section">
            <div class="section-heading">
                <div>
                    <h1>Games Library</h1>
                    <p>Search the full catalog, jump pages quickly, and scan games without squinting through tiny cards.</p>
                </div>
            </div>
            <div class="stack">
                <div class="search-shell">
                    <div class="search-container">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" placeholder="Search games" id="searchbar" value="<%= search || '' %>">
                    </div>
                    <div class="pagination-container">
                        <span class="page-note">Page</span>
                        <input type="number" class="page-input" id="currentPage" min="1" value="<%= currentPage %>">
                        <span class="page-note">of <span class="total-pages" id="totalPages"><%= totalPages %></span></span>
                    </div>
                </div>

                <div class="portal-grid">
                    <% if (games.length === 0) { %>
                        <div class="centered-empty grid-span-full">
                            No games matched "<%= search %>". Try a shorter search or clear the filter.
                        </div>
                    <% } %>
                    <% games.forEach((game, index) => { %>
                        <a class="game-card g" href="/play/<%= encodeURIComponent(game.name) %>">
                            <% if (game.prev) { %>
                                <img src="<%= game.prev %>" alt="<%= game.name %>" loading="<%= index < 8 ? 'eager' : 'lazy' %>" decoding="async">
                            <% } else { %>
                                <img src="/d/<%= encodeURIComponent(game.name.replace(/\//g, '')) %>.jpg" alt="<%= game.name %>" loading="<%= index < 8 ? 'eager' : 'lazy' %>" decoding="async">
                            <% } %>
                            <div class="game-card-body">
                                <div class="game-card-label"><span class="material-symbols-outlined">sports_esports</span>Ready to play</div>
                                <h3><%= game.name %></h3>
                            </div>
                        </a>
                    <% }); %>
                </div>

                <div class="toolbar-shell">
                    <% const prevPage = Math.max(1, currentPage - 1); %>
                    <% const nextPage = Math.min(totalPages, currentPage + 1); %>
                    <a class="button-ghost" href="?page=<%= prevPage %><%= search ? '&search=' + encodeURIComponent(search) : '' %>">Previous</a>
                    <a class="button-secondary" href="?page=<%= nextPage %><%= search ? '&search=' + encodeURIComponent(search) : '' %>">Next Page</a>
                    <div
                        class="canlite-ad-slot"
                        data-placement-id="games-toolbar"
                        data-ad-type="banner"
                        data-width="728"
                        data-height="90"
                    ></div>
                    <p class="hint">Need help with a game listing or want something removed? Email canlite24@outlook.com or use <a href="https://docs.google.com/forms/d/e/1FAIpQLSd6RQqR6QMTSPjVwBMedaPs39Yqk2Z_aXw0zomFClf62tokmg/viewform?usp=dialog">this form</a>.</p>
                </div>
            </div>
        </section>
    </main>
</div>

<script>
    window.__CANLITE_AD_CONTEXT = {
        visitHash: <%- JSON.stringify(visitHash) %>,
        pageUrl: window.location.href,
        pageTitle: "CanLite Games Library",
        pageContext: "Browse the CanLite games library."
    };

    document.getElementById('searchbar').addEventListener("keydown", function(event) {
        if(event.key === 'Enter') {
            const url = new URL(window.location.href);
            url.searchParams.delete("page");
            if (this.value.trim()) {
                url.searchParams.set("search", this.value.trim());
            } else {
                url.searchParams.delete("search");
            }
            window.location.href = url;
        }
    });

    document.getElementById("currentPage").addEventListener("change", function () {
        let page = parseInt(this.value);
        let totalPages = <%= totalPages %>;

        if (page < 1) page = 1;
        if (page > totalPages) page = totalPages;

        const url = new URL(window.location.href);
        url.searchParams.set("page", page);
        window.location.href = url;
    });
</script>

