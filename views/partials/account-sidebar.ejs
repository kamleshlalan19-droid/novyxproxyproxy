<aside class="account-sidebar">
    <div class="account-sidebar-card account-sidebar-frame">
        <nav class="account-nav">
            <button class="account-nav-link <%= currentPage === 'account' ? 'active' : '' %>" type="button" data-account-panel-target="account">
                <span class="material-symbols-outlined">person</span>
                <span>Account</span>
            </button>
            <button class="account-nav-link <%= currentPage === 'link-management' ? 'active' : '' %>" type="button" data-account-panel-target="link-management">
                <span class="material-symbols-outlined">link</span>
                <span>Link Management</span>
            </button>
            <% if (showPrivateLinkAdmin || currentPage === 'private-link-admin') { %>
                <button class="account-nav-link <%= currentPage === 'private-link-admin' ? 'active' : '' %>" type="button" data-account-panel-target="private-link-admin">
                    <span class="material-symbols-outlined">shield_lock</span>
                    <span>Link Admin</span>
                </button>
            <% } %>
        </nav>

        <div class="account-sidebar-stats">
            <div>
                <span>Balance</span>
                <strong id="credit-balance"><%= credits %> credits</strong>
            </div>
            <div>
                <span>Account</span>
                <strong><%= email %></strong>
            </div>
        </div>
    </div>
</aside>
