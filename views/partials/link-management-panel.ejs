<% const isPrivateLinkOwner = !privateLink || privateLink.role === 'owner' || Boolean(privateLinks && privateLinks.length); %>
<section class="account-panel <%= initialPanel === 'link-management' ? 'is-active' : '' %>" data-account-panel="link-management" <%= initialPanel === 'link-management' ? '' : 'hidden' %>>
    <div class="section-heading">
        <div>
            <h1>Private Links</h1>
            <p>Choose whether to use your own domain or let CanLite generate the private link domain, then add the cover link and secret login path.</p>
        </div>
    </div>

    <div class="manager-grid">
        <section class="manager-section manager-section-editor">
            <div class="manager-section-head">
                <div>
                    <h2 id="private-link-editor-title">Create Or Edit</h2>
                    <p id="private-link-editor-summary">Step 1: choose your private link type, then add a cover link and secret login path.</p>
                </div>
            </div>

            <div class="private-link-callout">
                <h3>Before You Start</h3>
                <p>If you use your own domain or subdomain, it must be brand new and never used before in the route database.</p>
                <p>Recommended: use <a href="https://freedns.afraid.org/" target="_blank" rel="noopener noreferrer">FreeDNS</a> to create a free subdomain, then point an <code>A</code> record to <code>104.36.85.249</code>.</p>
                <p>If you let CanLite generate the private link, the domain will be assigned automatically when you save.</p>
            </div>

            <form id="private-link-form" class="private-link-form">
                <div class="field-grid">
                    <label class="field">
                        <span>Private link type</span>
                        <select id="private-link-source" class="styled-select" <%= isPrivateLinkOwner ? '' : 'disabled' %>>
                            <option value="byo" selected>I have my own domain</option>
                            <option value="provided">Generate one with CanLite</option>
                        </select>
                        <small>Choose whether you want to use your own hostname or have CanLite assign one.</small>
                    </label>
                    <label class="field">
                        <span>Secret login path</span>
                        <input id="private-link-login-path" type="text" placeholder="/notes" value="/login" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                        <small>This is the hidden path you visit to open the private CanLite page.</small>
                    </label>
                </div>

                <div id="private-link-domain-group" class="field-grid">
                    <label class="field">
                        <span>Private domain</span>
                        <input id="private-link-domain" type="text" placeholder="study.example.com" value="" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                        <small>Use a hostname you control and point its <code>A</code> record to <code>104.36.85.249</code>. It must also be brand new to the route database or creation will be rejected.</small>
                    </label>
                </div>

                <div class="field-grid">
                    <label class="field">
                        <span>Cover link</span>
                        <input id="private-link-cover-url" type="url" placeholder="https://google.com" value="" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                        <small>This is required. Paste the exact cover link you want the private link to open.</small>
                    </label>
                </div>

                <div id="private-link-generated-note" class="private-link-empty" hidden>
                    CanLite will generate the private-link domain for you when you save. You still need to provide the cover link above.
                </div>

                <% if (isPrivateLinkOwner) { %>
                    <div class="button-row">
                        <button id="private-link-save" type="submit" class="button">Save Setup</button>
                        <button id="private-link-clear" type="button" class="button-ghost">Clear Form</button>
                    </div>
                <% } else { %>
                    <div class="private-link-empty">Only the link owner can change this domain, cover link, login path, or member access.</div>
                <% } %>
            </form>

            <p id="private-link-feedback" class="private-link-feedback"></p>
        </section>

        <section class="manager-section">
            <div class="manager-section-head">
                <div>
                    <h3>Your Private Links</h3>
                    <p>Each account can own up to 5 private links.</p>
                </div>
            </div>
            <div id="private-link-list" class="private-link-list"></div>
        </section>
    </div>
</section>
