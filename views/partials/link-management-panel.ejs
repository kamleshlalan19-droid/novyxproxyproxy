<% const isPrivateLinkOwner = !privateLink || privateLink.role === 'owner' || Boolean(privateLinks && privateLinks.length); %>
<section class="account-panel <%= initialPanel === 'link-management' ? 'is-active' : '' %>" data-account-panel="link-management" <%= initialPanel === 'link-management' ? '' : 'hidden' %>>
    <div class="section-heading">
        <div>
            <h1>Private Links</h1>
            <p>Set up your real private link here: pick a private domain, a secret login path, and a normal-looking cover site.</p>
            <p>Important: your private domain must be brand new and never used before in the route database.</p>
        </div>
    </div>

    <div class="manager-grid">
        <section class="manager-section manager-section-editor">
            <div class="manager-section-head">
                <div>
                    <h2 id="private-link-editor-title">Create Or Edit</h2>
                    <p id="private-link-editor-summary">Step 1: fill this out to make or update a real private link.</p>
                </div>
            </div>

            <div class="private-link-callout">
                <h3>Before You Start</h3>
                <p>You need your own domain or subdomain for a private link. Raw IP addresses do not work here.</p>
                <p>Recommended: use <a href="https://freedns.afraid.org/" target="_blank" rel="noopener noreferrer">FreeDNS</a> to create a free subdomain, then point an <code>A</code> record to <code>104.36.85.249</code>.</p>
                <p>When the DNS record is live, enter that hostname here. Then choose a secret login path and a normal cover site.</p>
            </div>

            <form id="private-link-form" class="private-link-form">
                <div class="field-grid">
                    <label class="field">
                        <span>Link type</span>
                        <select id="private-link-source" class="styled-select" <%= isPrivateLinkOwner ? '' : 'disabled' %>>
                            <option value="byo" selected>Bring your own link</option>
                            <option value="provided" disabled>Use a provided link (disabled)</option>
                        </select>
                        <small>This is your own domain or subdomain.</small>
                    </label>
                    <label class="field">
                        <span>Secret login path</span>
                        <input id="private-link-login-path" type="text" placeholder="/notes" value="/login" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                        <small>This is the hidden path you visit to open the private CanLite page.</small>
                    </label>
                </div>

                <div class="field-grid">
                    <label class="field">
                        <span>Private domain</span>
                        <input id="private-link-domain" type="text" placeholder="study.example.com" value="" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                        <small>Use a hostname you control and point its <code>A</code> record to <code>104.36.85.249</code>. It must also be brand new to the route database or creation will be rejected.</small>
                    </label>
                    <label class="field">
                        <span>Cover site</span>
                        <input id="private-link-cover-url" type="url" placeholder="https://google.com" value="" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                        <small>People who visit your private domain normally will see this site unless they use your secret login path.</small>
                    </label>
                </div>

                <% if (isPrivateLinkOwner) { %>
                    <div class="button-row">
                        <button id="private-link-save" type="submit" class="button">Save Setup</button>
                        <button id="private-link-clear" type="button" class="button-ghost">Clear Form</button>
                    </div>
                <% } else { %>
                    <div class="private-link-empty">Only the link owner can change this domain, cover URL, login path, or member access.</div>
                <% } %>
            </form>

            <p id="private-link-feedback" class="private-link-feedback"></p>
        </section>

        <section class="manager-section">
            <div class="manager-section-head">
                <div>
                    <h3>Quick Link Generator</h3>
                    <p>Optional: make a quick shareable link here. This is separate from your private domain setup above.</p>
                </div>
            </div>

            <form id="private-link-create-form" class="private-link-form">
                <label class="field">
                    <span>Provided URL</span>
                    <input id="private-link-create-url" type="url" placeholder="https://example.org/path">
                    <small>If you paste a URL here, CanLite just gives that back to you. Leave it blank to generate one instead.</small>
                </label>

                <div class="field-grid">
                    <label class="field">
                        <span>Site</span>
                        <select id="private-link-create-site" class="styled-select">
                            <option value="CanLite">CanLite</option>
                            <option value="BrunysIXL">BrunysIXL</option>
                        </select>
                    </label>
                    <label class="field">
                        <span>Filter</span>
                        <select id="private-link-create-filter" class="styled-select">
                            <option value="blocksi">Blocksi</option>
                            <option value="cisco">Cisco</option>
                            <option value="iboss">iBoss</option>
                            <option value="lanschool">LanSchool</option>
                            <option value="lightspeed">Lightspeed</option>
                            <option value="linewize">Linewize</option>
                            <option value="senso">Senso</option>
                        </select>
                    </label>
                </div>

                <div class="button-row">
                    <button id="private-link-create-submit" type="submit" class="button">Create Link</button>
                </div>
            </form>

            <label class="field" style="margin-top: 16px;">
                <span>Created Link</span>
                <input id="private-link-create-result" type="text" readonly placeholder="Your quick link will appear here.">
            </label>
        </section>

        <section class="manager-section">
            <div class="manager-section-head">
                <div>
                    <h3>Your Private Links</h3>
                    <p>Each account can own up to 5 private links.</p>
                </div>
            </div>
            <div id="private-link-list" class="private-link-list"></div>
        </section>
    </div>
</section>
