<% const isPrivateLinkOwner = !privateLink || privateLink.role === 'owner'; %>
<% const isPrivateLinkHost = Boolean(privateLink && privateLink.activeHost); %>
<% const hasPaidPrivateLink = Boolean(privateLink && Number(privateLink.monthlyCostCredits) > 0); %>
<section class="account-panel <%= initialPanel === 'link-management' ? 'is-active' : '' %>" data-account-panel="link-management" <%= initialPanel === 'link-management' ? '' : 'hidden' %>>
    <div class="section-heading">
        <div>
            <h1>Link Management</h1>
        </div>
    </div>

    <div class="manager-grid">
        <section class="manager-section">
            <div class="manager-section-head">
                <div>
                    <h2>Create Or Edit</h2>
                </div>
            </div>

            <form id="private-link-form" class="private-link-form">
                <div class="field-grid">
                    <label class="field">
                        <span>Link type</span>
                        <select id="private-link-source" class="styled-select" <%= isPrivateLinkOwner ? '' : 'disabled' %>>
                            <option value="byo" selected>Bring your own link</option>
                            <option value="provided" disabled>Use a provided link (disabled)</option>
                        </select>
                    </label>
                    <label class="field">
                        <span>Login path</span>
                        <input id="private-link-login-path" type="text" placeholder="/secret-login" value="/login" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                    </label>
                </div>

                <div class="field-grid">
                    <label class="field">
                        <span>Private domain</span>
                        <input id="private-link-domain" type="text" placeholder="study.example.com" value="" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                    </label>
                    <label class="field">
                        <span>Cover URL</span>
                        <input id="private-link-cover-url" type="url" placeholder="https://example.org" value="" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                    </label>
                </div>

                <% if (isPrivateLinkOwner) { %>
                    <div class="button-row">
                        <button id="private-link-save" type="submit" class="button">Save Private Link</button>
                        <button id="private-link-clear" type="button" class="button-ghost">Clear Form</button>
                    </div>
                <% } else { %>
                    <div class="private-link-empty">Only the link owner can change this domain, cover URL, login path, or member access.</div>
                <% } %>
            </form>

            <p id="private-link-feedback" class="private-link-feedback"></p>
        </section>

        <section class="manager-section">
            <div class="manager-section-head">
                <div>
                    <h3>Your Private Links</h3>
                </div>
            </div>
            <div id="private-link-list" class="private-link-list"></div>
        </section>

        <section id="private-link-owner-tools" class="manager-section" <%= privateLink && privateLink.role === 'owner' && isPrivateLinkHost ? '' : 'hidden' %>>
            <div class="manager-section-head">
                <div>
                    <h3>People With Access</h3>
                </div>
            </div>
            <form id="private-link-member-form" class="inline-form">
                <label class="field">
                    <span>Add account email</span>
                    <input id="private-link-member-email" type="email" placeholder="friend@example.com">
                </label>
                <button type="submit" class="button">Add Person</button>
            </form>
            <div id="private-link-members" class="member-list"></div>
        </section>

        <% if (isPrivateLinkHost && hasPaidPrivateLink) { %>
            <section class="manager-section">
                <div class="manager-section-head">
                    <div>
                        <h3>Slush Pool</h3>
                    </div>
                </div>

                <div class="slush-summary">
                    <div class="private-link-stat">
                        <span>Link cost</span>
                        <strong id="link-cost-credits"><%= privateLink ? privateLink.monthlyCostCredits : 0 %> credits / month</strong>
                    </div>
                    <div class="private-link-stat">
                        <span>Current pool</span>
                        <strong id="private-link-slush-pool"><%= privateLink ? privateLink.slushPoolCredits : 0 %> credits</strong>
                    </div>
                </div>

                <form id="private-link-contribution-form" class="private-link-form">
                    <label class="field">
                        <span>Chip into the link</span>
                        <input id="private-link-contribution-amount" type="number" min="0.01" step="0.01" placeholder="5">
                    </label>
                    <div class="button-row">
                        <button type="submit" class="button">Contribute Credits</button>
                    </div>
                </form>

                <div>
                    <h3 style="margin-bottom: 10px;">Contribution Totals</h3>
                    <div id="private-link-contributions" class="contribution-list"></div>
                </div>
            </section>
        <% } %>
    </div>
</section>
