<% const isPrivateLinkOwner = !privateLink || privateLink.role === 'owner' || Boolean(privateLinks && privateLinks.length); %>
<section class="account-panel <%= initialPanel === 'link-management' ? 'is-active' : '' %>" data-account-panel="link-management" <%= initialPanel === 'link-management' ? '' : 'hidden' %>>
    <div class="section-heading">
        <div>
            <h1>Private Links</h1>
            <p>Set the cover site people should see before login, then choose whether the private-link URL itself is user-provided or generated by the local CanLite API.</p>
        </div>
    </div>

    <div class="manager-grid">
        <section class="manager-section manager-section-editor">
            <div class="manager-section-head">
                <div>
                    <h2 id="private-link-editor-title">Create Or Edit</h2>
                    <p id="private-link-editor-summary">Step 1: choose how the private-link URL should be created, then set the cover site and secret login path.</p>
                </div>
            </div>

            <div class="private-link-callout">
                <h3>Before You Start</h3>
                <p>The cover site is always user-provided. That is what people see before they log in.</p>
                <p>The private-link URL people visit can either be pasted directly or generated using CanLite.</p>
                <p>If you paste the private-link URL yourself, its hostname still needs to be brand new and never used before in the route database.</p>
            </div>

            <form id="private-link-form" class="private-link-form">
                <div class="field-grid">
                    <label class="field">
                        <span>Private-link URL source</span>
                        <select id="private-link-source" class="styled-select" <%= isPrivateLinkOwner ? '' : 'disabled' %>>
                            <option value="byo" selected>I already have the private-link URL</option>
                            <option value="provided">Generate the private-link URL with CanLite</option>
                        </select>
                        <small>This controls the actual URL people visit, not the cover site.</small>
                    </label>
                    <label class="field">
                        <span>Secret login path</span>
                        <input id="private-link-login-path" type="text" placeholder="/notes" value="/login" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                        <small>This is the hidden path you visit to open the private CanLite page.</small>
                    </label>
                </div>

                <div id="private-link-manual-url-group" class="field-grid">
                    <label class="field">
                        <span>Private-link URL</span>
                        <input id="private-link-url" type="url" placeholder="https://study.example.com" value="" <%= isPrivateLinkOwner ? '' : 'readonly' %>>
                        <small>Paste the exact URL people should visit. Its hostname must be brand new to the route database.</small>
                    </label>
                </div>

                <div id="private-link-filter-group" class="field-grid" hidden>
                    <label class="field">
                        <span>Filter</span>
                        <select id="private-link-filter" class="styled-select" <%= isPrivateLinkOwner ? '' : 'disabled' %>>
                            <option value="">Choose a filter</option>
                            <option value="blocksi">Blocksi</option>
                            <option value="cisco">Cisco</option>
                            <option value="iboss">iBoss</option>
                            <option value="lanschool">LanSchool</option>
                            <option value="lightspeed">Lightspeed</option>
                            <option value="linewize">Linewize</option>
                            <option value="senso">Senso</option>
                        </select>
                        <small>The generator always uses CanLite. Pick the filter it should generate for.</small>
                    </label>
                </div>

                <div class="field-grid">
                    <label class="field">
                        <span>Cover site URL</span>
                        <input id="private-link-cover-url" type="url" placeholder="https://google.com" value="" <%= isPrivateLinkOwner ? '' : 'readonly' %> required>
                        <small>This is always user-provided. People who are not logged in get sent here.</small>
                    </label>
                </div>

                <div id="private-link-generated-note" class="private-link-empty" hidden>
                    CanLite will generate the private-link URL people visit. The cover site above still stays user-provided.
                </div>

                <% if (isPrivateLinkOwner) { %>
                    <div class="button-row">
                        <button id="private-link-save" type="submit" class="button">Save Setup</button>
                        <button id="private-link-clear" type="button" class="button-ghost">Clear Form</button>
                    </div>
                <% } else { %>
                    <div class="private-link-empty">Only the link owner can change this private-link URL, cover site, login path, or member access.</div>
                <% } %>
            </form>

            <p id="private-link-feedback" class="private-link-feedback"></p>
        </section>

        <section class="manager-section">
            <div class="manager-section-head">
                <div>
                    <h3>Your Private Links</h3>
                    <p>Each account can own up to 5 private links.</p>
                </div>
            </div>
            <div id="private-link-list" class="private-link-list"></div>
        </section>
    </div>
</section>
