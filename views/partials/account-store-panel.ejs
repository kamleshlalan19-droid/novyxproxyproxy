<section class="account-panel <%= initialPanel === 'account' ? 'is-active' : '' %>" data-account-panel="account" <%= initialPanel === 'account' ? '' : 'hidden' %>>
    <div class="section-heading">
        <div>
            <h1>Your Account</h1>
        </div>
    </div>

    <div class="store-summary">
        <article class="store-stat">
            <span class="store-kicker"><span class="material-symbols-outlined">savings</span>Balance</span>
            <strong><%= credits %> credits</strong>
        </article>
        <article class="store-stat">
            <span class="store-kicker"><span class="material-symbols-outlined">visibility_off</span>Ad-Free</span>
            <strong><%= adfree.active ? "Active" : "Inactive" %></strong>
            <p>
                <% if (adfree.active) { %>
                    Ends <%= adfree.expiresAt.toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" }) %> with about <%= adfree.daysRemaining %> days left.
                <% } else { %>
                    Buy ad-free access at the same rate as before: 1 credit per day.
                <% } %>
            </p>
        </article>
        <article class="store-stat">
            <span class="store-kicker"><span class="material-symbols-outlined">mail</span>Account</span>
            <strong><%= email %></strong>
        </article>
    </div>

    <article class="info-card">
        <div class="section-heading" style="margin-bottom: 18px;">
            <div>
                <h2>Store</h2>
            </div>
        </div>

        <div class="store-note">
            <a href="/offerwall">Open Offerwall</a>
        </div>

        <div class="store-actions" style="margin-top: 18px;">
            <article class="store-card">
                <h3>Ad-Free for 7 Days</h3>
                <div class="price-row">
                    <div class="store-price">7 credits</div>
                </div>
                <button class="button store-button" data-plan="week" data-label="7 days" type="button">Buy 7 Days</button>
            </article>
            <article class="store-card">
                <h3>Ad-Free for 30 Days</h3>
                <div class="price-row">
                    <div class="store-price">25 credits</div>
                </div>
                <button class="button store-button" data-plan="month" data-label="1 month" type="button">Buy 1 Month</button>
            </article>
            <article class="store-card">
                <h3>Ad-Free Lifetime</h3>
                <div class="price-row">
                    <div class="store-price">100 credits</div>
                </div>
                <button class="button store-button" data-plan="lifetime" data-label="lifetime" type="button">Buy Lifetime</button>
            </article>
        </div>

        <p id="store-feedback" style="margin-top: 16px;"></p>

        <div class="perk-grid" style="margin-top: 10px;">
            <article class="perk-card">
                <h3>Bring Your Own Private Link</h3>
                <div class="price-row">
                    <div class="store-price">0 credits / month</div>
                </div>
                <button class="button-ghost panel-link-trigger" data-account-panel-target="link-management" type="button">Open Link Management</button>
            </article>
            <article class="perk-card">
                <h3>Provided Private Links</h3>
                <div class="price-row">
                    <div class="store-price">10 credits / month</div>
                    <span class="coming-soon">Coming soon</span>
                </div>
                <button class="button-ghost store-button" type="button" disabled>Coming soon</button>
            </article>
            <article class="perk-card">
                <h3>Semi-Private Links</h3>
                <div class="price-row">
                    <div class="store-price">5 credits / month</div>
                    <span class="coming-soon">Coming soon</span>
                </div>
                <button class="button-ghost store-button" type="button" disabled>Coming soon</button>
            </article>
        </div>
    </article>

    <div class="detail-grid">
        <article class="info-card">
            <h3>Discord Link</h3>
            <p>Link your Discord account so the CanLite bot can recognize you and dispense proxy links there.</p>
            <div class="discord-link-card" id="discord-link-card">
                <% if (discordLink?.linked && discordLink?.link) { %>
                    <div class="discord-link-status is-linked">
                        <span class="store-kicker"><span class="material-symbols-outlined">link</span>Linked</span>
                        <strong id="discord-link-name"><%= discordLink.link.discord_global_name || discordLink.link.discord_username || "Discord account" %></strong>
                        <p id="discord-link-meta">Discord username: <%= discordLink.link.discord_username || "unknown" %></p>
                    </div>
                <% } else { %>
                    <div class="discord-link-status">
                        <span class="store-kicker"><span class="material-symbols-outlined">link_off</span>Not Linked</span>
                        <strong id="discord-link-name">No Discord account connected</strong>
                        <p id="discord-link-meta">Generate a one-time code here, then use it in the Discord bot with <code>/link</code>.</p>
                    </div>
                <% } %>

                <div class="discord-link-code-box">
                    <span>One-time link code</span>
                    <strong id="discord-link-code"><%= discordLink?.pendingCode?.code || "Not generated yet" %></strong>
                    <p id="discord-link-code-expiry">
                        <% if (discordLink?.pendingCode?.expiresAt) { %>
                            Expires <%= new Date(discordLink.pendingCode.expiresAt).toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" }) %>
                        <% } else { %>
                            Codes stay active for 15 minutes.
                        <% } %>
                    </p>
                </div>

                <div class="button-row">
                    <button id="discord-generate-code" type="button" class="button">Generate Code</button>
                    <button id="discord-unlink-button" type="button" class="button-ghost" <%= discordLink?.linked ? "" : "disabled" %>>Unlink Discord</button>
                </div>
                <p id="discord-link-feedback"></p>
            </div>
        </article>

        <article class="info-card">
            <h3>Switch Site</h3>
            <p>Use this to switch the active site override for your session. Private-link creation is now available directly from Link Management.</p>
            <form action="/api/switch" method="POST" class="stack" style="margin-top:18px;">
                <label for="site-select">Choose a site</label>
                <select id="site-select" name="site" class="styled-select">
                    <option value="https://trigonometry.texasmath.net">US5</option>
                    <option value="https://gr4ys0n.github.io">Gaming Escape</option>
                    <option value="https://securedweb.xyz">Secured Web</option>
                    <option value="https://flamepass.com">Flamepass</option>
                    <option value="https://watch.bludclart.com">Bludclart</option>
                    <option value="https://wqgqvswarit.swarit.104.36.84.31.nip.io/">Pizza Edition</option>
                </select>
                <div class="button-row">
                    <button type="submit" class="button">Switch</button>
                </div>
            </form>
        </article>

        <article class="info-card">
            <h3>Session</h3>
            <div class="button-row" style="margin-top:18px;">
                <button id="logout-button" type="button" class="button-ghost">Logout</button>
            </div>
        </article>
    </div>
</section>
