<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta description="CanLite account area">
    <meta name="viewport" content="width=device-width">
    <title><%= initialPanel === "link-management" ? "Private Links" : "Your Account" %></title>
    <script defer data-domain="trueanalytics.online" src="https://trueanalyticz.online/js/script.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <script type="text/javascript" src="/partner.js"></script>
    <script src="/theme.js"></script>
    <link rel="stylesheet" href="/site.css">
    <link rel="stylesheet" href="/settings/style.css">
    <link rel="stylesheet" href="/account/layout.css">
    <link rel="stylesheet" href="/account/account.css">
    <link rel="stylesheet" href="/account/link-management.css">
</head>
<body>
<% const showPrivateLinkAdmin = Boolean(privateLink && privateLink.activeHost); %>
<div class="noise"></div>
<div class="site-shell">
    <%- include("partials/app-header", { brandKicker: "Account", activeSection: null }) %>

    <main class="page">
        <section class="site-section">
            <div class="account-layout">
                <%- include("partials/account-sidebar", {
                    currentPage: initialPanel,
                    showPrivateLinkAdmin,
                    credits,
                    email
                }) %>

                <div class="account-main">
                    <div class="account-panels" data-initial-account-panel="<%= initialPanel %>">
                        <%- include("partials/account-store-panel", { initialPanel, credits, email, adfree, discordLink }) %>
                        <%- include("partials/link-management-panel", { initialPanel, privateLink, privateLinks }) %>
                        <%- include("partials/private-link-admin-panel", { initialPanel, privateLink }) %>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include("partials/app-footer") %>
</div>

<script>
    document.getElementById('year').textContent = new Date().getFullYear();

    const accountPanelsRoot = document.querySelector('.account-panels');
    const accountPanelNodes = Array.from(document.querySelectorAll('[data-account-panel]'));
    const accountPanelTriggers = Array.from(document.querySelectorAll('[data-account-panel-target]'));
    let activeAccountPanel = accountPanelsRoot?.dataset.initialAccountPanel || 'account';

    const syncAccountPanelState = (panelName) => {
        for (const panel of accountPanelNodes) {
            const isActive = panel.dataset.accountPanel === panelName;
            panel.hidden = !isActive;
            panel.classList.toggle('is-active', isActive);
        }

        for (const trigger of accountPanelTriggers) {
            const isActive = trigger.dataset.accountPanelTarget === panelName;
            trigger.classList.toggle('active', isActive);
            trigger.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        }

        activeAccountPanel = panelName;
    };

    const switchAccountPanel = (panelName) => {
        if (!panelName || panelName === activeAccountPanel) {
            return;
        }

        syncAccountPanelState(panelName);
        document.title = panelName === 'link-management'
            ? 'Private Links'
            : panelName === 'private-link-admin'
                ? 'Private Link Admin'
                : 'Your Account';
    };

    for (const trigger of accountPanelTriggers) {
        trigger.addEventListener('click', () => {
            switchAccountPanel(trigger.dataset.accountPanelTarget);
        });
    }

    syncAccountPanelState(activeAccountPanel);

    const feedback = document.getElementById('store-feedback');
    const balanceEl = document.getElementById('credit-balance');

    for (const button of document.querySelectorAll('[data-plan]')) {
        button.addEventListener('click', async () => {
            const plan = button.dataset.plan;
            const label = button.dataset.label || 'ad-free access';
            button.disabled = true;
            feedback.textContent = 'Processing purchase...';

            try {
                const response = await fetch('/api/store/adfree', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ plan })
                });

                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Purchase failed');
                }

                balanceEl.textContent = `${data.credits} credits`;
                feedback.textContent = `Purchased ${label} of ad-free access. Reloading...`;
                window.setTimeout(() => window.location.reload(), 700);
            } catch (error) {
                feedback.textContent = error.message || 'Purchase failed';
            } finally {
                button.disabled = false;
            }
        });
    }

    document.getElementById('logout-button').addEventListener('click', async () => {
        await fetch('/api/logout', { method: 'POST' });
        window.location.href = '/';
    });

    const discordLinkFeedback = document.getElementById('discord-link-feedback');
    const discordGenerateCodeButton = document.getElementById('discord-generate-code');
    const discordUnlinkButton = document.getElementById('discord-unlink-button');
    const discordLinkName = document.getElementById('discord-link-name');
    const discordLinkMeta = document.getElementById('discord-link-meta');
    const discordLinkCode = document.getElementById('discord-link-code');
    const discordLinkCodeExpiry = document.getElementById('discord-link-code-expiry');
    const discordLinkStatus = document.querySelector('.discord-link-status');
    let discordLinkState = <%- JSON.stringify(discordLink || null) %>;

    const setDiscordFeedback = (message, isError = false) => {
        if (!discordLinkFeedback) {
            return;
        }

        discordLinkFeedback.textContent = message || '';
        discordLinkFeedback.classList.toggle('error', Boolean(isError));
    };

    const renderDiscordLinkState = (state) => {
        discordLinkState = state || null;

        if (!discordLinkName || !discordLinkMeta || !discordLinkCode || !discordLinkCodeExpiry || !discordLinkStatus) {
            return;
        }

        if (state?.linked && state?.link) {
            discordLinkStatus.classList.add('is-linked');
            discordLinkName.textContent = state.link.discord_global_name || state.link.discord_username || 'Discord account';
            discordLinkMeta.textContent = `Discord username: ${state.link.discord_username || 'unknown'}`;
            if (discordUnlinkButton) {
                discordUnlinkButton.disabled = false;
            }
        } else {
            discordLinkStatus.classList.remove('is-linked');
            discordLinkName.textContent = 'No Discord account connected';
            discordLinkMeta.innerHTML = 'Generate a one-time code here, then use it in the Discord bot with <code>/link</code>.';
            if (discordUnlinkButton) {
                discordUnlinkButton.disabled = true;
            }
        }

        if (state?.pendingCode?.code) {
            discordLinkCode.textContent = state.pendingCode.code;
            discordLinkCodeExpiry.textContent = `Expires ${new Date(state.pendingCode.expiresAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' })}`;
        } else {
            discordLinkCode.textContent = 'Not generated yet';
            discordLinkCodeExpiry.textContent = 'Codes stay active for 15 minutes.';
        }
    };

    if (discordGenerateCodeButton) {
        discordGenerateCodeButton.addEventListener('click', async () => {
            discordGenerateCodeButton.disabled = true;
            setDiscordFeedback('Generating Discord link code...');

            try {
                const response = await fetch('/api/discord/link-code', { method: 'POST' });
                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to generate Discord link code');
                }

                renderDiscordLinkState(data.discordLink);
                setDiscordFeedback('Discord link code generated. Use it in the bot with /link.');
            } catch (error) {
                setDiscordFeedback(error.message || 'Failed to generate Discord link code', true);
            } finally {
                discordGenerateCodeButton.disabled = false;
            }
        });
    }

    if (discordUnlinkButton) {
        discordUnlinkButton.addEventListener('click', async () => {
            discordUnlinkButton.disabled = true;
            setDiscordFeedback('Removing Discord link...');

            try {
                const response = await fetch('/api/discord/unlink', { method: 'POST' });
                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to unlink Discord account');
                }

                renderDiscordLinkState(data.discordLink);
                setDiscordFeedback('Discord account unlinked.');
            } catch (error) {
                setDiscordFeedback(error.message || 'Failed to unlink Discord account', true);
                renderDiscordLinkState(discordLinkState);
            } finally {
                discordUnlinkButton.disabled = !(document.querySelector('.discord-link-status')?.classList.contains('is-linked'));
            }
        });
    }

    let activePrivateLinkState = <%- JSON.stringify(privateLink || null) %>;
    let privateLinksState = <%- JSON.stringify(privateLinks || []) %>;
    let privateLinkState = null;
    let editingPrivateLinkId = null;
    const canManagePrivateLink = <%- JSON.stringify((!privateLink || privateLink.role === 'owner') || Boolean(privateLinks && privateLinks.length)) %>;
    const privateLinkFeedback = document.getElementById('private-link-feedback');
    const privateLinkForm = document.getElementById('private-link-form');
    const privateLinkSaveButton = document.getElementById('private-link-save');
    const privateLinkEditorTitle = document.getElementById('private-link-editor-title');
    const privateLinkEditorSummary = document.getElementById('private-link-editor-summary');
    const privateLinkOwnerTools = document.getElementById('private-link-owner-tools');
    const privateLinkList = document.getElementById('private-link-list');
    const privateLinkMembers = document.getElementById('private-link-members');
    const privateLinkContributions = document.getElementById('private-link-contributions');
    const privateLinkSlushPool = document.getElementById('private-link-slush-pool');
    const privateLinkContributionSection = document.getElementById('private-link-contribution-section');
    const privateLinkMemberLabel = document.getElementById('private-link-member-label');
    const privateLinkMemberSummary = document.getElementById('private-link-member-summary');
    const privateLinkMemberSubmit = document.getElementById('private-link-member-submit');
    const privateLinkAdminSummary = document.getElementById('private-link-admin-summary');
    const privateLinkAdminEmpty = document.getElementById('private-link-admin-empty');
    const privateLinkSourceInput = document.getElementById('private-link-source');
    const privateLinkDomainGroup = document.getElementById('private-link-domain-group');
    const privateLinkDomainInput = document.getElementById('private-link-domain');
    const privateLinkCoverUrlInput = document.getElementById('private-link-cover-url');
    const privateLinkLoginPathInput = document.getElementById('private-link-login-path');
    const privateLinkGeneratedNote = document.getElementById('private-link-generated-note');
    const getPrivateLinkSourceLabel = (linkSource) => (
        linkSource === 'provided' ? 'generated by CanLite' : 'bring your own'
    );

    const normalizeOwnedPrivateLinks = (links, activeLink) =>
        (Array.isArray(links) ? links : []).map((link) => ({
            ...link,
            role: 'owner',
            activeHost: Boolean(activeLink && Number(activeLink.id) === Number(link.id) && activeLink.activeHost),
        }));

    const findOwnedPrivateLinkById = (linkId) =>
        privateLinksState.find((link) => Number(link.id) === Number(linkId)) || null;

    const syncSelectedPrivateLink = (selectedLinkId = null) => {
        if (selectedLinkId) {
            privateLinkState =
                findOwnedPrivateLinkById(selectedLinkId) ||
                (activePrivateLinkState && Number(activePrivateLinkState.id) === Number(selectedLinkId) ? activePrivateLinkState : null);
        } else if (privateLinkState?.id) {
            privateLinkState =
                findOwnedPrivateLinkById(privateLinkState.id) ||
                (activePrivateLinkState && Number(activePrivateLinkState.id) === Number(privateLinkState.id) ? activePrivateLinkState : null);
        }

        if (!privateLinkState) {
            privateLinkState =
                (activePrivateLinkState && activePrivateLinkState.role === 'member' ? activePrivateLinkState : null) ||
                privateLinksState[0] ||
                activePrivateLinkState ||
                null;
        }
    };

    const applyPrivateLinkResponse = (data) => {
        activePrivateLinkState = data?.privateLink || activePrivateLinkState;
        privateLinksState = normalizeOwnedPrivateLinks(data?.privateLinks || privateLinksState, activePrivateLinkState);
        syncSelectedPrivateLink(data?.selectedLinkId || editingPrivateLinkId);
    };

    privateLinksState = normalizeOwnedPrivateLinks(privateLinksState, activePrivateLinkState);
    syncSelectedPrivateLink(activePrivateLinkState?.role === 'owner' ? activePrivateLinkState?.id : null);

    const getCurrentPrivateLinkDomain = () => privateLinkState?.domain || 'this private link';
    const getRenderedPrivateLinks = () => (
        privateLinksState.length
            ? privateLinksState
            : (privateLinkState ? [privateLinkState] : [])
    );

    const syncPrivateLinkFormMode = () => {
        if (!privateLinkSourceInput || !privateLinkDomainInput) {
            return;
        }

        const usesGeneratedDomain = privateLinkSourceInput.value === 'provided';
        if (privateLinkDomainGroup) {
            privateLinkDomainGroup.hidden = usesGeneratedDomain;
        }
        if (privateLinkGeneratedNote) {
            privateLinkGeneratedNote.hidden = !usesGeneratedDomain;
            privateLinkGeneratedNote.textContent = editingPrivateLinkId && privateLinkState?.linkSource === 'provided' && privateLinkState?.domain
                ? `CanLite generated ${privateLinkState.domain} for this link. You still need to provide the cover link above.`
                : 'CanLite will generate the private-link domain for you when you save. You still need to provide the cover link above.';
        }

        privateLinkDomainInput.disabled = usesGeneratedDomain || !canManagePrivateLink;
        privateLinkDomainInput.required = !usesGeneratedDomain;
        if (usesGeneratedDomain) {
            privateLinkDomainInput.value = '';
        }
    };

    const clearPrivateLinkForm = () => {
        editingPrivateLinkId = null;
        privateLinkSourceInput.value = 'byo';
        privateLinkDomainInput.value = '';
        privateLinkCoverUrlInput.value = '';
        privateLinkLoginPathInput.value = '/login';
        syncPrivateLinkFormMode();
    };

    const loadPrivateLinkIntoForm = (link) => {
        if (!link) {
            clearPrivateLinkForm();
            return;
        }

        editingPrivateLinkId = link.id;
        privateLinkSourceInput.value = link.linkSource || 'byo';
        privateLinkDomainInput.value = link.linkSource === 'provided' ? '' : (link.domain || '');
        privateLinkCoverUrlInput.value = link.coverUrl || '';
        privateLinkLoginPathInput.value = link.loginPath || '/login';
        syncPrivateLinkFormMode();
    };

    const setPrivateLinkFeedback = (message, isError = false) => {
        if (!privateLinkFeedback) {
            return;
        }

        privateLinkFeedback.textContent = message || '';
        privateLinkFeedback.classList.toggle('error', Boolean(isError));
    };

    const escapeHtml = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
    }[char]));

    const renderPrivateLinkState = () => {
        if (!privateLinkList) {
            return;
        }

        const renderedLinks = getRenderedPrivateLinks();
        const adminPrivateLinkState = activePrivateLinkState?.activeHost ? activePrivateLinkState : null;
        const members = adminPrivateLinkState?.members || [];
        const contributions = adminPrivateLinkState?.contributionSummary || [];
        const isOwner = adminPrivateLinkState?.role === 'owner';
        const hasPaidAdminPrivateLink = Boolean(adminPrivateLinkState && Number(adminPrivateLinkState.monthlyCostCredits) > 0);
        const adminDomain = adminPrivateLinkState?.domain || 'this private link';

        if (privateLinkOwnerTools) {
            privateLinkOwnerTools.hidden = !isOwner;
        }

        if (privateLinkContributionSection) {
            privateLinkContributionSection.hidden = !hasPaidAdminPrivateLink;
        }

        if (privateLinkAdminEmpty) {
            privateLinkAdminEmpty.hidden = Boolean(adminPrivateLinkState);
        }

        if (privateLinkAdminSummary) {
            privateLinkAdminSummary.textContent = adminPrivateLinkState?.domain
                ? `Managing ${adminDomain}. These tools only work while you are on this private-link host.`
                : 'Open this page on the private link you want to manage.';
        }

        if (privateLinkMemberLabel) {
            privateLinkMemberLabel.textContent = adminPrivateLinkState?.domain
                ? `Add account email or linked Discord to ${adminDomain}`
                : 'Add account email or linked Discord to this private link';
        }

        if (privateLinkMemberSummary) {
            privateLinkMemberSummary.textContent = adminPrivateLinkState?.domain
                ? `Add or remove up to 19 invited accounts on ${adminDomain} by email or linked Discord. Each private link allows 20 total people including the owner.`
                : 'Add or remove up to 19 invited accounts on this private link by email or linked Discord. Each private link allows 20 total people including the owner.';
        }

        if (privateLinkMemberSubmit) {
            privateLinkMemberSubmit.textContent = adminPrivateLinkState?.domain
                ? `Add User To ${adminDomain}`
                : 'Add User To Link';
        }

        if (privateLinkEditorTitle) {
            privateLinkEditorTitle.textContent = editingPrivateLinkId ? 'Edit Private Link' : 'Create Private Link';
        }

        if (privateLinkEditorSummary) {
            privateLinkEditorSummary.textContent = editingPrivateLinkId && privateLinkState?.domain
                ? `Editing ${privateLinkState.domain}. Clear the form if you want to start a brand-new setup instead.`
                : 'Step 1: choose your private link type, then add a cover link and secret login path.';
        }

        if (privateLinkSaveButton) {
            privateLinkSaveButton.textContent = editingPrivateLinkId ? 'Save Changes' : 'Create Private Link';
        }

        privateLinkList.innerHTML = renderedLinks.length
            ? renderedLinks.map((link) => {
                const isSelected = editingPrivateLinkId && Number(link.id) === Number(editingPrivateLinkId);
                const memberTotal = (link.members?.length || 0) + 1;
                return `
                <article class="private-link-card${isSelected ? ' is-selected' : ''}">
                    <div class="private-link-card-head">
                        <div>
                            <strong>${escapeHtml(link.domain)}</strong>
                        </div>
                        <div class="private-link-badge-row">
                            <span class="private-link-badge">${escapeHtml(link.role || 'owner')}</span>
                            <span class="private-link-badge">${escapeHtml(getPrivateLinkSourceLabel(link.linkSource))}</span>
                            ${link.activeHost ? '<span class="private-link-badge">current host</span>' : ''}
                        </div>
                    </div>
                    <div class="private-link-card-grid">
                        <div class="private-link-stat">
                            <span>Private domain</span>
                            <input class="private-link-value" type="text" readonly value="${escapeHtml(`https://${link.domain}`)}" onclick="this.select()">
                        </div>
                        <div class="private-link-stat">
                            <span>Secret login path</span>
                            <input class="private-link-value" type="text" readonly value="${escapeHtml(link.loginPath)}" onclick="this.select()">
                        </div>
                        <div class="private-link-stat">
                            <span>Cover link</span>
                            <input class="private-link-value" type="text" readonly value="${escapeHtml(link.coverUrl)}" onclick="this.select()">
                        </div>
                        <div class="private-link-stat">
                            <span>Monthly cost</span>
                            <strong>${link.monthlyCostCredits} credits</strong>
                        </div>
                        <div class="private-link-stat">
                            <span>People with access</span>
                            <strong>${memberTotal} / 20</strong>
                        </div>
                    </div>
                    ${canManagePrivateLink ? `
                        <div class="private-link-card-meta">
                            <button type="button" class="button-ghost button-tiny" data-edit-private-link="${link.id}">${isSelected ? 'Editing' : 'Edit Link'}</button>
                        </div>
                    ` : ''}
                </article>
            `;
            }).join('')
            : '<div class="private-link-empty">No private links yet. Start with the setup form above. You can create up to 5 private links.</div>';

        if (privateLinkMembers) {
            privateLinkMembers.innerHTML = members.length
                ? members.map((member) => `
                    <div class="member-row">
                        <div>
                            <strong>${escapeHtml(member.email)}</strong>
                            <span>${member.discordUsername || member.discordGlobalName ? `Discord: ${escapeHtml(member.discordGlobalName || member.discordUsername)} • ` : ''}Access granted on ${escapeHtml(adminDomain)}</span>
                        </div>
                        ${isOwner ? `<button class="button-ghost button-tiny" type="button" data-remove-member="${member.userId}">Remove</button>` : ''}
                    </div>
                `).join('')
                : '<div class="private-link-empty">No extra members yet.</div>';
        }

        if (privateLinkContributions) {
            privateLinkContributions.innerHTML = contributions.length
                ? contributions.map((contribution) => `
                    <div class="contribution-row">
                        <div>
                            <strong>${escapeHtml(contribution.email)}</strong>
                            <span>${contribution.totalCredits} credits contributed</span>
                        </div>
                    </div>
                `).join('')
                : '<div class="private-link-empty">No credits have been chipped in yet.</div>';
        }

        if (privateLinkSlushPool && hasPaidAdminPrivateLink) {
            privateLinkSlushPool.textContent = `${adminPrivateLinkState?.slushPoolCredits ?? 0} credits`;
        } else if (privateLinkSlushPool) {
            privateLinkSlushPool.textContent = '0 credits';
        }

        if (privateLinkContributions && !hasPaidAdminPrivateLink) {
            privateLinkContributions.innerHTML = '';
        }
    };

    if (privateLinkForm) {
        if (privateLinkState && canManagePrivateLink) {
            loadPrivateLinkIntoForm(privateLinkState);
        } else {
            clearPrivateLinkForm();
        }
        renderPrivateLinkState();

        privateLinkList.addEventListener('click', (event) => {
            const editButton = event.target.closest('[data-edit-private-link]');
            if (!editButton || !canManagePrivateLink) {
                return;
            }

            const link = findOwnedPrivateLinkById(editButton.dataset.editPrivateLink);
            if (!link) {
                return;
            }

            privateLinkState = link;
            loadPrivateLinkIntoForm(link);
            renderPrivateLinkState();
            setPrivateLinkFeedback(`Loaded ${link.domain} into the editor.`);
        });

        if (privateLinkSourceInput) {
            privateLinkSourceInput.addEventListener('change', () => {
                syncPrivateLinkFormMode();
                setPrivateLinkFeedback('');
            });
        }

        const privateLinkClearButton = document.getElementById('private-link-clear');
        if (privateLinkClearButton) {
            privateLinkClearButton.addEventListener('click', () => {
                clearPrivateLinkForm();
                renderPrivateLinkState();
                setPrivateLinkFeedback('');
            });
        }

        privateLinkForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            if (!canManagePrivateLink) {
                setPrivateLinkFeedback('Only the link owner can change this private link.', true);
                return;
            }

            const payload = {
                id: editingPrivateLinkId,
                linkSource: privateLinkSourceInput.value,
                domain: privateLinkSourceInput.value === 'provided' ? '' : privateLinkDomainInput.value,
                coverUrl: privateLinkCoverUrlInput.value,
                loginPath: privateLinkLoginPathInput.value
            };

            setPrivateLinkFeedback('Saving private link...');

            try {
                const response = await fetch('/api/private-links', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to save private link');
                }

                applyPrivateLinkResponse(data);
                if (data.selectedLinkId) {
                    loadPrivateLinkIntoForm(privateLinkState);
                } else {
                    clearPrivateLinkForm();
                }
                renderPrivateLinkState();
                setPrivateLinkFeedback(`Private link saved. Next, test https://${privateLinkState.domain}${privateLinkState.loginPath}.`);
            } catch (error) {
                setPrivateLinkFeedback(error.message || 'Failed to save private link', true);
            }
        });
    }

    const privateLinkMemberForm = document.getElementById('private-link-member-form');
    if (privateLinkMemberForm) {
        privateLinkMemberForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            const identifier = document.getElementById('private-link-member-email').value.trim();
            if (!identifier) {
                setPrivateLinkFeedback(`Enter an email or linked Discord account to add to ${activePrivateLinkState?.domain || 'this private link'}.`, true);
                return;
            }

            setPrivateLinkFeedback(`Adding user to ${activePrivateLinkState?.domain || 'this private link'}...`);

            try {
                const response = await fetch('/api/private-links/members', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ identifier })
                });

                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to add member');
                }

                applyPrivateLinkResponse(data);
                document.getElementById('private-link-member-email').value = '';
                renderPrivateLinkState();
                setPrivateLinkFeedback(`User added to ${activePrivateLinkState?.domain || 'this private link'}.`);
            } catch (error) {
                setPrivateLinkFeedback(error.message || 'Failed to add member', true);
            }
        });
    }

    if (privateLinkMembers) {
        privateLinkMembers.addEventListener('click', async (event) => {
            const button = event.target.closest('[data-remove-member]');
            if (!button) {
                return;
            }

            setPrivateLinkFeedback(`Removing user from ${activePrivateLinkState?.domain || 'this private link'}...`);

            try {
                const response = await fetch(`/api/private-links/members/${button.dataset.removeMember}`, {
                    method: 'DELETE'
                });

                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to remove member');
                }

                applyPrivateLinkResponse(data);
                renderPrivateLinkState();
                setPrivateLinkFeedback(`User removed from ${activePrivateLinkState?.domain || 'this private link'}.`);
            } catch (error) {
                setPrivateLinkFeedback(error.message || 'Failed to remove member', true);
            }
        });
    }

    const privateLinkContributionForm = document.getElementById('private-link-contribution-form');
    if (privateLinkContributionForm) {
        privateLinkContributionForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            const amount = Number(document.getElementById('private-link-contribution-amount').value);
            if (!amount) {
                setPrivateLinkFeedback('Enter a contribution amount.', true);
                return;
            }

            setPrivateLinkFeedback('Contributing credits...');

            try {
                const response = await fetch('/api/private-links/contribute', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ amount })
                });

                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to contribute credits');
                }

                balanceEl.textContent = `${data.credits} credits`;
                applyPrivateLinkResponse(data);
                document.getElementById('private-link-contribution-amount').value = '';
                renderPrivateLinkState();
                setPrivateLinkFeedback('Credits added to the slush pool.');
            } catch (error) {
                setPrivateLinkFeedback(error.message || 'Failed to contribute credits', true);
            }
        });
    }
</script>
<script src="/games/time.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="/settings/index.js"></script>
</body>
</html>
