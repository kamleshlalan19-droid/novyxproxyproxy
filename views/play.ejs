<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Play <%= game.name %> on CanLite">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0">
    <title>Play <%= game.name %> | CanLite</title>
    <link id="favicon" rel="icon" href="/favicon.ico" type="image/x-icon">
    <script src="/theme.js"></script>
    <link rel="stylesheet" href="/site.css">
    <link rel="stylesheet" href="/games/play.css">
    <script async defer data-domain="trueanalytics.online" src="https://trueanalyticz.online/js/script.js"></script>
    <script src="../partner/index.js"></script>
    <link rel="stylesheet" href="/login/style.css" />
    <link rel="stylesheet" href="/settings/style.css" />
    <script type="text/javascript" src="/partner.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const baseUrl = "https://canlite.org";
            const currentPath = window.location.pathname;
            const currentSearch = window.location.search;
            const canonicalUrl = baseUrl + currentPath + currentSearch;

            let link = document.querySelector("link[rel='canonical']");
            if (!link) {
                link = document.createElement("link");
                link.setAttribute("rel", "canonical");
                document.head.appendChild(link);
            }
            link.setAttribute("href", canonicalUrl);
        });
        const path = window.location.pathname;

        const match = path.match(/^\/play\/([^\/]+)/);
        if (match) {
            const game = match[1];

            try {
                 fetch(`/api/hit/${game}`, {
                    method: "GET",
                    headers: {
                        "Content-Type": "application/json",
                    }
                });
            } catch (err) {
                console.error("Failed to send hit:", err);
            }
        }
    </script>
    <script defer src="/uv/uv.bundle.js"></script>
    <script defer src="/uv/uv.config.js"></script>
</head>
<body>
<div class="noise"></div>
<div id="authModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <div class="modal-tabs">
            <button id="loginTab" class="active">Login</button>
            <button id="registerTab">Register</button>
        </div>
        <div id="loginForm" class="auth-form">
            <h2>Login</h2>
            <form>
                <label for="loginEmail">Email</label>
                <input type="email" id="loginEmail" placeholder="Enter your email" required>
                <label for="loginPassword">Password</label>
                <input type="password" id="loginPassword" placeholder="Enter your password" required>
                <label class="auth-consent" for="loginConsent">
                    <input type="checkbox" id="loginConsent" required>
                    <span>I agree to the current <a href="/terms" target="_blank" rel="noopener noreferrer">Terms</a> and <a href="/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>, including account-linked signal collection.</span>
                </label>
                <button type="submit">Login</button>
                <p id="loginStatus"></p>
            </form>
        </div>
        <div id="registerForm" class="auth-form auth-form-hidden">
            <h2>Register</h2>
            <form>
                <label for="registerEmail">Email</label>
                <input type="email" id="registerEmail" placeholder="Enter your email" required>
                <label for="registerPassword">Password</label>
                <input type="password" id="registerPassword" placeholder="Enter your password" required>
                <label class="auth-consent" for="registerConsent">
                    <input type="checkbox" id="registerConsent" required>
                    <span>I agree to the current <a href="/terms" target="_blank" rel="noopener noreferrer">Terms</a> and <a href="/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>, including account-linked signal collection.</span>
                </label>
                <button type="submit">Register</button>
                <p id="registerStatus"></p>
            </form>
        </div>
    </div>
</div>

<% const blockedHosts = [
    "everyonegetsnews.org",
    "canlite.org",
    "psybolt.com",
    "free-web-proxy.org"
]; %>
<% const gameHref = game.type === 'html5'
    ? game.path
    : `/games/embed?content=${encodeURIComponent(game.path)}&gameid=${encodeURIComponent(game.type)}`; %>

<div class="site-shell">
    <header class="site-header">
        <nav class="site-nav">
            <a class="brand" href="/">
                <img src="/logo.png" alt="Logo">
                <div class="brand-copy">
                    <span class="brand-kicker">Play</span>
                    <span class="brand-name">CanLite</span>
                </div>
            </a>
            <div class="nav-links">
                <a class="nav-link" href="/"><span class="material-symbols-outlined">home</span>Home</a>
                <a class="nav-link active" href="/games"><span class="material-symbols-outlined">stadia_controller</span>Games</a>
                <a class="nav-link" href="/proxe"><span class="material-symbols-outlined">language</span>Proxy</a>
                <a class="nav-link" href="/extra"><span class="material-symbols-outlined">add</span>Extra</a>
                <a class="nav-link" href="/partners"><span class="material-symbols-outlined">group</span>Partners</a>
                <a class="nav-link" href="https://discord.com/invite/46gkEU5kpP"><span class="material-symbols-outlined">forum</span>Discord</a>
            </div>
            <div class="nav-tools">
                <a id="settingsBtn" class="utility-chip" href="#"><span class="material-symbols-outlined">settings</span>Settings</a>
                <a id="loginModalBtn" class="utility-chip" href="#"><span id="loginSpan" class="material-symbols-outlined">login</span>Login</a>
                <div class="utility-chip clock-chip" id="time-clock"></div>
            </div>
        </nav>
    </header>

    <main class="page">
        <section class="site-section">
            <div class="section-heading">
                <div>
                    <h1><%= game.name %></h1>
                </div>
                <div class="hero-actions">
                    <a class="button-secondary" href="/games">Back to games</a>
                    <button class="button-ghost" id="copyLinkBtn" type="button">Copy link</button>
                </div>
            </div>

            <div class="embed-layout">
                <div class="glass-panel player-shell">
                    <div class="player-meta-row">
                        <div class="player-meta-chip">
                            <span class="material-symbols-outlined">bolt</span>
                            <span>Play</span>
                        </div>
                        <div class="player-meta-chip">
                            <span class="material-symbols-outlined">open_in_full</span>
                            <span>Fullscreen</span>
                        </div>
                        <div class="player-meta-chip">
                            <span class="material-symbols-outlined">favorite</span>
                            <span>Favorites</span>
                        </div>
                    </div>

                    <div class="embed-container embed-container-enhanced" id="playerShell">
                        <div class="player-status" id="playerStatus">
                            <div class="player-status-card" id="playerStatusCard">
                                <div class="player-spinner" id="playerSpinner"></div>
                                <div class="player-status-copy">
                                    <span class="eyebrow">Launching</span>
                                    <h2 id="playerStatusTitle">Preparing <%= game.name %></h2>
                                    <p id="playerStatusText">The game frame is loading. If it takes a while, you can refresh the player or open it in a dedicated tab.</p>
                                </div>
                                <div class="player-status-actions">
                                    <button class="button-secondary" id="retryLoadBtn" type="button">Retry load</button>
                                    <button class="button-ghost" id="openExternalBtn" type="button">Open in new tab</button>
                                </div>
                            </div>
                        </div>

                        <div id="game-container" class="game-frame-shell">
                            <iframe
                                id="gameFrame"
                                title="Play <%= game.name %>"
                                loading="eager"
                                allow="fullscreen; autoplay; gamepad *; clipboard-read; clipboard-write"
                                referrerpolicy="no-referrer"
                            ></iframe>
                        </div>
                    </div>

                    <div class="player-toolbar">
                        <div class="player-toolbar-group">
                            <button class="player-action-btn" id="refresh-btn" type="button" title="Reload game">
                                <span class="material-symbols-outlined">refresh</span>
                                <span>Reload</span>
                            </button>
                            <button class="player-action-btn" id="fullscreen-btn" type="button" title="Fullscreen">
                                <span class="material-symbols-outlined">fullscreen</span>
                                <span>Fullscreen</span>
                            </button>
                            <button class="player-action-btn" id="fit-btn" type="button" title="Toggle fit mode">
                                <span class="material-symbols-outlined">fit_screen</span>
                                <span>Fit</span>
                            </button>
                        </div>
                        <div class="player-toolbar-group">
                            <button class="player-action-btn" id="like-btn" type="button" title="Save favorite">
                                <span class="material-symbols-outlined">favorite</span>
                                <span>Favorite</span>
                            </button>
                            <button class="player-action-btn" id="newtab-btn" type="button" title="Open in new tab">
                                <span class="material-symbols-outlined">open_in_new</span>
                                <span>New tab</span>
                            </button>
                        </div>
                    </div>

                    <aside class="promo-card player-ad-card">
                        <h3>Advertisement</h3>
                        <div
                            id="playSidebarAdSlot"
                            class="canlite-ad-slot"
                            data-placement-id="play-sidebar"
                            data-ad-type="banner"
                            data-width="300"
                            data-height="250"
                        ></div>
                    </aside>
                </div>

                <div class="stack">
                    <aside class="promo-card">
                        <h3>Description</h3>
                        <p><%= game.desc || "No description has been added for this title yet." %></p>
                    </aside>
                    <aside class="promo-card">
                        <h3>Latest update</h3>
                        <p><%= new Date(game.date).toLocaleDateString("en-US") %></p>
                    </aside>
                    <aside class="promo-card">
                        <h3>Play tips</h3>
                        <p>Use fit mode or fullscreen if you want more space. If the game does not load, try reload.</p>
                    </aside>
                    <aside class="promo-card">
                        <h3>Status</h3>
                        <p id="playerSideStatus">Waiting for the game to report in.</p>
                    </aside>
                </div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <div class="footer-main">
            <div class="footer-links">
                <a href="/privacy">Privacy Policy</a>
                <a href="/terms">Terms of Service</a>
                <a href="mailto:canlite24@outlook.com">Email Us</a>
                <a href="https://discord.com/invite/46gkEU5kpP" target="_blank">Join our Discord</a>
                <a href="/about">About Us</a>
            </div>
            <div class="footer-copy">&copy; <span id="year"></span> CanLite. All rights reserved.</div>
        </div>
    </footer>
</div>

<script>
    const canliteGameName = <%- JSON.stringify(game.name).replace(/<\//g, "<\\/") %>;
    const canliteGameDescription = <%- JSON.stringify(game.desc || "").replace(/<\//g, "<\\/") %>;
    const canliteGameTagsRaw = <%- JSON.stringify(game.tags || "").replace(/<\//g, "<\\/") %>;
    const canliteVisitHash = <%- JSON.stringify(visitHash || null).replace(/<\//g, "<\\/") %>;
    window.__CANLITE_AD_CONTEXT = {
        visitHash: canliteVisitHash,
        pageUrl: window.location.href,
        pageTitle: canliteGameName,
        pageContext: canliteGameDescription
    };

    document.getElementById('year').textContent = new Date().getFullYear();
    if(localStorage.getItem('token')) {
        window.addEventListener("storage", () => {
            const localStorageData = { ...localStorage };
            delete localStorageData.token;
            let token = localStorage.getItem('token');
            fetch("https://" + window.location.hostname + `/api/saveGameData`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ token, localStorageData }),
            })
                .then(response => response.json())
                .then(data => console.log("LocalStorage data saved:", data))
                .catch(error => console.error("Error saving localStorage data:", error));
        });
    }

    const initializePlayPage = function () {
        const gameName = canliteGameName;
        const gameDescription = canliteGameDescription;
        const gameType = <%- JSON.stringify(game.type).replace(/<\//g, "<\\/") %>;
        const gamePath = <%- JSON.stringify(game.path).replace(/<\//g, "<\\/") %>;
        const openTarget = <%- JSON.stringify(gameHref).replace(/<\//g, "<\\/") %>;
        const iframe = document.getElementById("gameFrame");
        const playerShell = document.getElementById("playerShell");
        const likeBtn = document.getElementById("like-btn");
        const fullscreenBtn = document.getElementById("fullscreen-btn");
        const retryLoadBtn = document.getElementById("retryLoadBtn");
        const newTabBtn = document.getElementById("newtab-btn");
        const refreshBtn = document.getElementById("refresh-btn");
        const fitBtn = document.getElementById("fit-btn");
        const openExternalBtn = document.getElementById("openExternalBtn");
        const copyLinkBtn = document.getElementById("copyLinkBtn");
        const playerStatus = document.getElementById("playerStatus");
        const playerStatusTitle = document.getElementById("playerStatusTitle");
        const playerStatusText = document.getElementById("playerStatusText");
        const playerSideStatus = document.getElementById("playerSideStatus");
        const playerSpinner = document.getElementById("playerSpinner");
        const playSidebarAdSlot = document.getElementById("playSidebarAdSlot");
        const gameTags = String(canliteGameTagsRaw).split(",").map((item) => item.trim()).filter(Boolean);
        let readyCheckInterval;
        let loadTimeout;
        let loadscreenAdRequested = false;
        let loadscreenAdImpressionSent = false;
        const debugSidebarAd = (...args) => {
            if (window.__CANLITE_AD_DEBUG === true) {
                console.debug("[play-sidebar-ad]", ...args);
            }
        };

        const buildAdSignals = () => {
            const rawTerms = [
                gameName,
                ...gameTags.slice(0, 6),
            ];
            const normalizedTerms = [];
            const seen = new Set();

            for (const term of rawTerms) {
                const value = String(term || "").trim().toLowerCase();
                if (!value || seen.has(value)) {
                    continue;
                }
                seen.add(value);
                normalizedTerms.push(value);
            }

            return normalizedTerms.slice(0, 8);
        };

        const resolveAdfreeState = async () => {
            if (window.userAdfree === true) {
                return true;
            }

            const token = localStorage.getItem("token");
            if (!token) {
                return false;
            }

            try {
                const response = await fetch("/api/check", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ token }),
                });

                if (!response.ok) {
                    return false;
                }

                const data = await response.json();
                if (data?.loggedIn && data?.adfree) {
                    window.userAdfree = true;
                    return true;
                }
            } catch (error) {
                console.error("Failed to resolve adfree state for play sidebar ad:", error);
            }

            return false;
        };

        const postAdEvent = async (auctionId, eventType, token) => {
            if (!auctionId || !eventType || !token) {
                debugSidebarAd("Skipped event post due to missing fields.", {
                    auctionId,
                    eventType,
                    hasToken: Boolean(token),
                });
                return;
            }

            try {
                debugSidebarAd("Posting ad event.", { auctionId, eventType });
                await fetch("/api/ads/events", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ auctionId, eventType, token }),
                });
                debugSidebarAd("Ad event posted.", { auctionId, eventType });
            } catch (error) {
                console.error("Failed to post play sidebar ad event:", error);
            }
        };

        const renderSidebarAd = async (result) => {
            const winner = result?.winner;
            if (!winner?.adm || !playSidebarAdSlot) {
                debugSidebarAd("Skipped render because ad markup or slot is missing.", {
                    hasAdm: Boolean(winner?.adm),
                    hasSlot: Boolean(playSidebarAdSlot),
                });
                return;
            }

            debugSidebarAd("Rendering sidebar ad.", {
                auctionId: result?.auction?.id || null,
                affiliate: winner?.affiliate === true,
                hasImpressionToken: Boolean(winner?.tracking?.impressionToken),
            });

            const frame = document.createElement("iframe");
            frame.className = "adserver-ad-frame";
            frame.width = String(winner.w || 300);
            frame.height = String(winner.h || 250);
            frame.loading = "eager";
            frame.referrerPolicy = "no-referrer";
            frame.setAttribute(
                "sandbox",
                "allow-scripts allow-forms allow-popups allow-popups-to-escape-sandbox allow-top-navigation-by-user-activation"
            );

            frame.style.border = "0";
            frame.style.display = "block";
            frame.style.width = "100%";
            frame.style.maxWidth = String(winner.w || 300) + "px";
            frame.style.height = String(winner.h || 250) + "px";
            frame.style.margin = "0 auto";

            playSidebarAdSlot.replaceChildren(frame);

            frame.srcdoc = [
                "<!DOCTYPE html>",
                "<html lang=\"en\">",
                "<head>",
                "  <meta charset=\"utf-8\">",
                "  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">",
                "  <base target=\"_top\">",
                "  <style>html,body{margin:0;padding:0;background:transparent;overflow:hidden;}a{text-decoration:none;}</style>",
                "</head>",
                "<body>",
                winner.adm,
                "</body>",
                "</html>",
            ].join("");

            if (!loadscreenAdImpressionSent && winner.tracking?.impressionToken) {
                loadscreenAdImpressionSent = true;
                await postAdEvent(result.auction?.id, "impression", winner.tracking.impressionToken);
            } else {
                debugSidebarAd("Skipped impression event post.", {
                    alreadySent: loadscreenAdImpressionSent,
                    hasImpressionToken: Boolean(winner?.tracking?.impressionToken),
                });
            }
        };

        const requestSidebarAd = async () => {
            if (loadscreenAdRequested) {
                return;
            }

            loadscreenAdRequested = true;
            debugSidebarAd("Sidebar ad request started.");

            if (await resolveAdfreeState()) {
                debugSidebarAd("Skipped sidebar ad request because user is adfree.");
                return;
            }

            const keywords = buildAdSignals();
            if (keywords.length === 0) {
                debugSidebarAd("Skipped sidebar ad request because there are no keywords.");
                return;
            }

            try {
                const controller = new AbortController();
                const timeoutId = window.setTimeout(() => controller.abort(), 2200);
                const response = await fetch("/api/ads/auction", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    signal: controller.signal,
                    body: JSON.stringify({
                        visitHash: window.__CANLITE_AD_CONTEXT?.visitHash || null,
                        placementId: playSidebarAdSlot?.dataset.placementId || "play-sidebar",
                        pageUrl: window.location.href,
                        pageTitle: gameName,
                        pageContext: gameDescription || gameName,
                        adType: playSidebarAdSlot?.dataset.adType || "banner",
                        width: Number(playSidebarAdSlot?.dataset.width || 300),
                        height: Number(playSidebarAdSlot?.dataset.height || 250),
                        keywords,
                        query: gameName,
                    }),
                });
                window.clearTimeout(timeoutId);
                const result = await response.json();
                debugSidebarAd("Auction response received.", {
                    ok: response.ok,
                    status: response.status,
                    hasWinner: Boolean(result?.winner),
                    hasAdm: Boolean(result?.winner?.adm),
                    affiliate: result?.winner?.affiliate === true,
                    hasImpressionToken: Boolean(result?.winner?.tracking?.impressionToken),
                });

                if (!response.ok || !result?.winner?.adm || result?.winner?.affiliate !== true) {
                    debugSidebarAd("Skipped sidebar ad render because auction result did not qualify.", {
                        ok: response.ok,
                        hasAdm: Boolean(result?.winner?.adm),
                        affiliate: result?.winner?.affiliate === true,
                    });
                    return;
                }

                await renderSidebarAd(result);
            } catch (error) {
                if (error?.name !== "AbortError") {
                    console.error("Failed to request play sidebar ad:", error);
                }
            }
        };

        const queueSidebarAdRequest = () => {
            window.setTimeout(() => {
                debugSidebarAd("Queue fired for sidebar ad request.");
                void requestSidebarAd();
            }, 0);
        };

        const getFavorites = () => {
            const favoritesJSON = localStorage.getItem("canlitefavorites");
            return favoritesJSON ? JSON.parse(favoritesJSON) : [];
        };

        const setFavoriteState = () => {
            const favorites = getFavorites();
            const saved = favorites.includes(gameName);
            likeBtn.dataset.active = String(saved);
            likeBtn.querySelector("span:last-child").textContent = saved ? "Saved" : "Favorite";
        };

        const setPlayerState = (state, title, text) => {
            playerShell.dataset.state = state;
            playerStatusTitle.textContent = title;
            playerStatusText.textContent = text;
            playerSideStatus.textContent = text;
            playerSpinner.style.display = state === "loading" ? "block" : "none";
            playerStatus.hidden = state === "ready";
        };

        const clearReadyWatchers = () => {
            window.clearTimeout(loadTimeout);
            window.clearInterval(readyCheckInterval);
        };

        const tryMarkReady = () => {
            try {
                const frameWindow = iframe.contentWindow;
                const frameDocument = iframe.contentDocument || frameWindow?.document;

                if (!frameWindow || !frameDocument) {
                    return false;
                }

                const href = frameWindow.location?.href || "";
                const readyState = frameDocument.readyState;
                const hasRenderableContent =
                    frameDocument.body &&
                    (frameDocument.body.childElementCount > 0 ||
                        frameDocument.body.textContent.trim().length > 0);

                if (
                    readyState === "complete" &&
                    href &&
                    href !== "about:blank" &&
                    hasRenderableContent
                ) {
                    clearReadyWatchers();
                    setPlayerState(
                        "ready",
                        `${gameName} is ready`,
                        "The game loaded successfully. Use reload if it freezes or switch to fullscreen for a cleaner layout."
                    );
                    return true;
                }
            } catch {
                // Cross-frame access can fail briefly while the proxy frame is settling.
            }

            return false;
        };

        const getLaunchUrl = () => {
            if (gameType !== "html5") {
                return openTarget;
            }

            const isExternal = /^https?:\/\//.test(gamePath);
            if (isExternal) {
                return window.location.origin + window.__uv$config.prefix + window.__uv$config.encodeUrl(gamePath);
            }
            return gamePath;
        };

        const armLoadTimeout = () => {
            clearReadyWatchers();
            loadTimeout = window.setTimeout(() => {
                setPlayerState(
                    "stalled",
                    "Still loading",
                    "The game is taking longer than expected. Try reloading the player or opening it in a dedicated tab."
                );
            }, 12000);
            readyCheckInterval = window.setInterval(tryMarkReady, 300);
        };

        const loadGame = async () => {
            setPlayerState(
                "loading",
                `Preparing ${gameName}`,
                "The game frame is loading. If it takes a while, you can refresh the player or open it in a dedicated tab."
            );

            if (gameType === "html5" && "serviceWorker" in navigator) {
                try {
                    await navigator.serviceWorker.register("/uv/sw.js", {
                        scope: window.__uv$config?.prefix || "/uv/"
                    });
                } catch (err) {
                    console.error("Service worker registration failed:", err);
                }
            }

            const launchUrl = getLaunchUrl();

            iframe.removeAttribute("src");
            iframe.src = launchUrl;
            armLoadTimeout();
        };

        iframe.addEventListener("load", () => {
            window.setTimeout(tryMarkReady, 120);
        });

        iframe.addEventListener("error", () => {
            clearReadyWatchers();
            setPlayerState(
                "error",
                "Unable to load the game",
                "This embed failed to start. Retry the load or open the game in a separate tab."
            );
        });

        likeBtn.addEventListener("click", function() {
            const favorites = getFavorites();
            const existingIndex = favorites.indexOf(gameName);
            if (existingIndex === -1) {
                favorites.push(gameName);
            } else {
                favorites.splice(existingIndex, 1);
            }

            localStorage.setItem("canlitefavorites", JSON.stringify(favorites));
            setFavoriteState();
        });

        newTabBtn.addEventListener("click", function () {
            window.open(iframe.src || getLaunchUrl(), "_blank", "noopener,noreferrer");
        });

        openExternalBtn.addEventListener("click", function () {
            window.open(iframe.src || getLaunchUrl(), "_blank", "noopener,noreferrer");
        });

        retryLoadBtn.addEventListener("click", loadGame);
        refreshBtn.addEventListener("click", loadGame);

        fitBtn.addEventListener("click", function () {
            const compact = playerShell.dataset.fit !== "compact";
            playerShell.dataset.fit = compact ? "compact" : "default";
            fitBtn.dataset.active = String(compact);
            fitBtn.querySelector("span:last-child").textContent = compact ? "Expanded" : "Fit";
        });

        fullscreenBtn.addEventListener("click", function () {
            const target = iframe.closest(".embed-container");
            if (!target) return;

            if (target.requestFullscreen) {
                target.requestFullscreen();
            } else if (target.webkitRequestFullscreen) {
                target.webkitRequestFullscreen();
            } else if (target.msRequestFullscreen) {
                target.msRequestFullscreen();
            }
        });

        copyLinkBtn.addEventListener("click", async function () {
            try {
                await navigator.clipboard.writeText(window.location.href);
                copyLinkBtn.textContent = "Copied";
                window.setTimeout(() => {
                    copyLinkBtn.textContent = "Copy link";
                }, 1600);
            } catch {
                copyLinkBtn.textContent = "Copy failed";
                window.setTimeout(() => {
                    copyLinkBtn.textContent = "Copy link";
                }, 1600);
            }
        });

        queueSidebarAdRequest();
        setFavoriteState();
        loadGame();
    };

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initializePlayPage, { once: true });
    } else {
        initializePlayPage();
    }
</script>

<script src="/login/index.js"></script>
<script src="/games/time.js"></script>
<script src="/settings/index.js"></script>
<% if (!blockedHosts.includes(hostname)) { %>
    <script async type='text/javascript' src='/api/ad' defer></script>
<% } %>
</body>
</html>
