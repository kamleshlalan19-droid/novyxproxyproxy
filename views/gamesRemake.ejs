<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CanLite - Games Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1655414789495559" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script async defer data-domain="trueanalytics.online" src="https://trueanalyticz.online/js/script.js"></script>
    <script src="/theme.js"></script>
    <link rel="stylesheet" href="/site.css" />
    <link rel="stylesheet" href="/games/home.css" />
    <link rel="stylesheet" href="/login/style.css" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const removeAdsInsideGameCard = () => {
                document.querySelectorAll(
                    '.game-card .google-auto-placed, ' +
                    '.game-card ins.adsbygoogle, ' +
                    '.game-card iframe[src*="googlesyndication"], ' +
                    '.game-card iframe[src*="doubleclick"]'
                ).forEach(el => el.remove());
            };

            removeAdsInsideGameCard();

            if (document.body) {
                const observer = new MutationObserver(removeAdsInsideGameCard);
                observer.observe(document.body, { childList: true, subtree: true });
            }
        });
    </script>
</head>
<body>
<div class="noise"></div>

<div id="authModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <div class="modal-tabs">
            <button id="loginTab" class="active">Login</button>
            <button id="registerTab">Register</button>
        </div>
        <div id="loginForm" class="auth-form">
            <h2>Login</h2>
            <form>
                <label for="loginEmail">Email</label>
                <input type="email" id="loginEmail" placeholder="Enter your email" required>
                <label for="loginPassword">Password</label>
                <input type="password" id="loginPassword" placeholder="Enter your password" required>
                <button type="submit">Login</button>
                <p id="loginStatus"></p>
            </form>
        </div>
        <div id="registerForm" class="auth-form auth-form-hidden">
            <h2>Register</h2>
            <form>
                <label for="registerEmail">Email</label>
                <input type="email" id="registerEmail" placeholder="Enter your email" required>
                <label for="registerPassword">Password</label>
                <input type="password" id="registerPassword" placeholder="Enter your password" required>
                <button type="submit">Register</button>
            </form>
        </div>
    </div>
</div>

<% const blockedHosts = [
    "everyonegetsnews.org",
    "canlite.org",
    "psybolt.com",
    "free-web-proxy.org"
]; %>

<div class="site-shell">
    <header class="site-header">
        <nav class="site-nav">
            <a class="brand" href="/">
                <img src="/logo.png" alt="CanLite">
                <div class="brand-copy">
                    <span class="brand-kicker">Games</span>
                    <span class="brand-name">CanLite</span>
                </div>
            </a>
            <div class="nav-links">
                <a class="nav-link" href="/"><span class="material-symbols-outlined">home</span>Home</a>
                <a class="nav-link active" href="/games"><span class="material-symbols-outlined">stadia_controller</span>Games</a>
                <a class="nav-link" href="/proxe"><span class="material-symbols-outlined">language</span>Proxy</a>
                <a class="nav-link" href="/extra"><span class="material-symbols-outlined">add</span>Extra</a>
                <a class="nav-link" href="/partners"><span class="material-symbols-outlined">group</span>Partners</a>
                <a class="nav-link" href="https://discord.com/invite/46gkEU5kpP"><span class="material-symbols-outlined">forum</span>Discord</a>
            </div>
            <div class="nav-tools">
                <a id="loginModalBtn" class="utility-chip" href="#"><span id="loginSpan" class="material-symbols-outlined">login</span>Login</a>
                <div class="utility-chip clock-chip" id="time-clock"></div>
            </div>
        </nav>
    </header>

    <main class="page">
        <section class="hero">
            <div class="hero-panel">
                <span class="eyebrow">Games</span>
                <h1>Browse games and start playing.</h1>
                <p class="hero-lead">Open featured games, check new additions, and jump back into your favorites.</p>
                <div class="button-row">
                    <a href="/newgames" class="button">View new games</a>
                    <a href="/allgames" class="button-secondary">Browse all titles</a>
                </div>
            </div>
            <div class="hero-panel hero-side">
                <div class="mini-panel">
                    <strong>Favorites</strong>
                    <p>Your saved games appear here when you come back.</p>
                </div>
                <div class="mini-panel">
                    <strong>Popular games</strong>
                    <p>The most-played titles show up first.</p>
                </div>
                <div class="mini-panel">
                    <strong>Full library</strong>
                    <p>Use the library pages to browse the full list.</p>
                </div>
            </div>
        </section>

        <section class="site-section">
            <div class="section-heading">
                <div>
                    <h2>Top Games</h2>
                    <p>The most-played games show up first so you can jump straight into the hits.</p>
                </div>
            </div>
            <div class="portal-grid portal-grid-featured">
                <% topGamesFirst.forEach(function(game) { %>
                    <a href="/play/<%= encodeURIComponent(game.name) %>" class="game-card">
                        <% if (game.prev) { %>
                            <img src="<%= game.prev %>" alt="<%= game.name %>" loading="eager" decoding="async">
                        <% } else { %>
                            <img src="/d/<%= encodeURIComponent(game.name.replace(/\//g, '')) %>.jpg" alt="<%= game.name %>" loading="eager" decoding="async">
                        <% } %>
                        <div class="game-card-body">
                            <div class="game-card-label"><span class="material-symbols-outlined">local_fire_department</span>Trending now</div>
                            <h3><%= game.name %></h3>
                            <p>Open the game and start playing.</p>
                        </div>
                    </a>
                <% }); %>
                <% topGamesRest.forEach(function(game) { %>
                    <a href="/play/<%= encodeURIComponent(game.name) %>" class="game-card">
                        <% if (game.prev) { %>
                            <img src="<%= game.prev %>" alt="<%= game.name %>" loading="lazy" decoding="async">
                        <% } else { %>
                            <img src="/d/<%= encodeURIComponent(game.name.replace(/\//g, '')) %>.jpg" alt="<%= game.name %>" loading="lazy" decoding="async">
                        <% } %>
                        <div class="game-card-body">
                            <div class="game-card-label"><span class="material-symbols-outlined">sports_esports</span>Popular pick</div>
                            <h3><%= game.name %></h3>
                        </div>
                    </a>
                <% }); %>
            </div>
        </section>

        <section class="site-section">
            <div class="section-heading">
                <div>
                    <h2>Your Favorites</h2>
                    <p>Your saved games show up here right away so your go-to picks are always close.</p>
                </div>
            </div>
            <div class="portal-grid" id="favorites-grid">
                <script>
                    function renderFavorites() {
                        const favorites = JSON.parse(localStorage.getItem('canlitefavorites') || '[]');
                        const favoritesGrid = document.getElementById('favorites-grid');

                        favoritesGrid.innerHTML = '';

                        if (favorites.length === 0) {
                            favoritesGrid.innerHTML = '<div class="centered-empty grid-span-full">No favorites yet. Tap the heart on any play page to build your own rail.</div>';
                            return;
                        }

                        favorites.forEach(gameSlug => {
                            const gameCard = document.createElement('a');
                            gameCard.className = 'game-card';
                            gameCard.href = `/play/${encodeURIComponent(gameSlug)}`;
                            gameCard.innerHTML = `
                                <img src="/api/img/${gameSlug}" alt="${gameSlug}">
                                <div class="game-card-body">
                                    <div class="game-card-label"><span class="material-symbols-outlined">favorite</span>Saved</div>
                                    <h3>${gameSlug}</h3>
                                </div>
                            `;

                            favoritesGrid.appendChild(gameCard);
                        });
                    }

                    renderFavorites();
                </script>
            </div>
        </section>
    </main>
</div>

<div id="particles-js"></div>

<script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
<script>
    particlesJS('particles-js', {
        particles: {
            number: { value: 80, density: { enable: true, value_area: 800 } },
            color: { value: '#18b7ff' },
            shape: { type: 'circle' },
            opacity: { value: 0.38, random: false },
            size: { value: 3, random: true },
            line_linked: { enable: true, distance: 150, color: '#7ee3ff', opacity: 0.24, width: 1 },
            move: { enable: true, speed: 3.5, direction: 'none', random: false, straight: false, out_mode: 'out', bounce: false }
        },
        interactivity: {
            detect_on: 'canvas',
            events: { onhover: { enable: true, mode: 'repulse' }, onclick: { enable: true, mode: 'push' }, resize: true },
            modes: { repulse: { distance: 140, duration: 0.3 }, push: { particles_nb: 4 } }
        },
        retina_detect: true
    });
</script>

<footer class="site-footer">
    <div class="footer-main">
        <div class="footer-links">
            <a href="/privacy">Privacy Policy</a>
            <a href="mailto:canlite24@outlook.com">Email Us</a>
            <a href="https://discord.com/invite/46gkEU5kpP" target="_blank">Join our Discord</a>
            <a href="/about">About Us</a>
        </div>
        <div class="footer-copy">&copy; <span id="year"></span> CanLite. All rights reserved.</div>
    </div>
</footer>

<script>
    document.getElementById('year').textContent = new Date().getFullYear();
</script>
<script src="/login/index.js"></script>
<script src="/games/time.js"></script>
<% if (!blockedHosts.includes(hostname)) { %>
    <script async type='text/javascript' src='/api/ad' defer></script>
<% } %>
</body>
</html>
