                            <option value="https://watch.bludclart.com">Bludclart</option>
                            <option value="https://wqgqvswarit.swarit.104.36.84.31.nip.io/">Pizza Edition</option>
                        </select>
                        <div class="button-row">
                            <button type="submit" class="button">Switch</button>
                        </div>
                    </form>
                    <form action="/api/logout" method="POST" style="margin-top:18px;">
                        <button type="submit" class="button-ghost">Logout</button>
                    </form>
                </article>
                <article class="info-card">
                    <h3>Disable Ads</h3>
                    <p>Complete a survey to disable ads for a week. It may take a few hours after completion before the account updates.</p>
                    <div class="button-row" style="margin-top:18px;">
                        <button class="button-secondary" onclick="window.location.href='/offerwall'" type="button">Disable Ads</button>
                    </div>
                </article>
            </div>
        </section>
    </main>

