<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta description="Unblocked Games on CanLite">
    <meta name="viewport" content="width=device-width">
    <title>Your Account</title>
    <script defer data-domain="trueanalytics.online" src="https://trueanalyticz.online/js/script.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <script type="text/javascript" src="/partner.js"></script>
    <script src="/theme.js"></script>
    <link rel="stylesheet" href="/site.css">
    <link rel="stylesheet" href="/settings/style.css">
    <style>
        .store-grid {
            display: grid;
            gap: 24px;
        }

        .store-summary {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }

        .store-stat,
        .store-card,
        .perk-card {
            background: rgba(14, 18, 31, 0.72);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 22px;
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.22);
        }

        .store-stat strong,
        .store-card strong,
        .perk-card strong {
            display: block;
            font-size: 1.7rem;
            margin-top: 10px;
        }

        .store-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            border-radius: 999px;
            background: rgba(127, 227, 190, 0.12);
            color: #9ff0ca;
            font-size: 0.86rem;
            font-weight: 600;
        }

        .store-actions,
        .perk-grid {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        }

        .store-card h3,
        .perk-card h3 {
            margin-bottom: 8px;
        }

        .store-card p,
        .perk-card p,
        .store-stat p {
            margin: 0;
            color: rgba(255, 255, 255, 0.72);
        }

        .price-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin: 18px 0 14px;
        }

        .price-row span {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.62);
        }

        .store-price {
            font-size: 1.55rem;
            font-weight: 700;
        }

        .store-note {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
            justify-content: space-between;
            padding: 16px 18px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.76);
        }

        .store-note a {
            color: #9ff0ca;
            font-weight: 600;
            text-decoration: none;
        }

        .store-button[disabled] {
            opacity: 0.55;
            cursor: not-allowed;
        }

        .coming-soon {
            color: #ffcf88;
            font-size: 0.9rem;
            font-weight: 600;
        }

        #store-feedback {
            min-height: 24px;
            color: #9ff0ca;
        }
    </style>
</head>

<body>
<div class="noise"></div>
<div class="site-shell">
    <header class="site-header">
        <nav class="site-nav">
            <a class="brand" href="/">
                <img src="/logo.png" alt="CanLite">
                <div class="brand-copy">
                    <span class="brand-kicker">Account</span>
                    <span class="brand-name">CanLite</span>
                </div>
            </a>
            <div class="nav-links">
                <a class="nav-link" href="/"><span class="material-symbols-outlined">home</span>Home</a>
                <a class="nav-link" href="/games"><span class="material-symbols-outlined">stadia_controller</span>Games</a>
                <a class="nav-link" href="/proxe"><span class="material-symbols-outlined">language</span>Proxy</a>
                <a class="nav-link" href="/extra"><span class="material-symbols-outlined">add</span>Extra</a>
                <a class="nav-link" href="/partners"><span class="material-symbols-outlined">group</span>Partners</a>
            </div>
            <div class="nav-tools">
                <a id="settingsBtn" class="utility-chip" href="#"><span class="material-symbols-outlined">settings</span>Settings</a>
                <div class="utility-chip clock-chip" id="time-clock"></div>
            </div>
        </nav>
    </header>

    <main class="page">
        <section class="site-section">
            <div class="section-heading">
                <div>
                    <h1>Your Account</h1>
                    <p>Manage this device, collect credits from the offerwall, and spend them in the store.</p>
                </div>
            </div>

            <div class="store-grid">
                <div class="store-summary">
                    <article class="store-stat">
                        <span class="store-kicker"><span class="material-symbols-outlined">savings</span>Balance</span>
                        <strong id="credit-balance"><%= credits %> credits</strong>
                        <p>Offerwall rewards now land here as store credits.</p>
                    </article>
                    <article class="store-stat">
                        <span class="store-kicker"><span class="material-symbols-outlined">visibility_off</span>Ad-Free</span>
                        <strong>
                            <% if (adfree.active) { %>
                                Active
                            <% } else { %>
                                Inactive
                            <% } %>
                        </strong>
                        <p>
                            <% if (adfree.active) { %>
                                Ends <%= adfree.expiresAt.toLocaleString("en-US", { dateStyle: "medium", timeStyle: "short" }) %> with about <%= adfree.daysRemaining %> days left.
                            <% } else { %>
                                Buy ad-free access at the same rate as before: 1 credit per day.
                            <% } %>
                        </p>
                    </article>
                    <article class="store-stat">
                        <span class="store-kicker"><span class="material-symbols-outlined">mail</span>Account</span>
                        <strong><%= email %></strong>
                        <p>Your credits and purchases are tied to this account.</p>
                    </article>
                </div>

                <article class="info-card">
                    <div class="section-heading" style="margin-bottom: 18px;">
                        <div>
                            <h2>Store</h2>
                            <p>Spend your balance on account perks. Private link products are listed now and locked until launch.</p>
                        </div>
                    </div>

                    <div class="store-note">
                        <span>Need more credits? Finish surveys on the offerwall and come back here to spend them.</span>
                        <a href="/offerwall">Open Offerwall</a>
                    </div>

                    <div class="store-actions" style="margin-top: 18px;">
                        <article class="store-card">
                            <h3>Ad-Free for 7 Days</h3>
                            <p>Removes ads for one week on the current account.</p>
                            <div class="price-row">
                                <div class="store-price">7 credits</div>
                                <span>1 credit per day</span>
                            </div>
                            <button class="button store-button" data-days="7" type="button">Buy 7 Days</button>
                        </article>
                        <article class="store-card">
                            <h3>Ad-Free for 30 Days</h3>
                            <p>Monthly option with a discounted store price.</p>
                            <div class="price-row">
                                <div class="store-price">25 credits</div>
                                <span>30 days of access</span>
                            </div>
                            <button class="button store-button" data-days="30" data-price="25" type="button">Buy 1 Month</button>
                        </article>
                        <article class="store-card">
                            <h3>Ad-Free Lifetime</h3>
                            <p>Permanent ad-free access for this account.</p>
                            <div class="price-row">
                                <div class="store-price">100 credits</div>
                                <span>One-time unlock</span>
                            </div>
                            <button class="button store-button" data-days="36500" data-price="100" type="button">Buy Lifetime</button>
                        </article>
                    </div>

                    <p id="store-feedback" style="margin-top: 16px;"></p>

                    <div class="perk-grid" style="margin-top: 10px;">
                        <article class="perk-card">
                            <h3>Private Links</h3>
                            <p>Reserved for fully private link access once the feature launches.</p>
                            <div class="price-row">
                                <div class="store-price">10 credits / month</div>
                                <span class="coming-soon">Coming soon</span>
                            </div>
                            <button class="button-ghost store-button" type="button" disabled>Private Links Locked</button>
                        </article>
                        <article class="perk-card">
                            <h3>Semi-Private Links</h3>
                            <p>Lower-cost tier for semi-private link access when it goes live.</p>
                            <div class="price-row">
                                <div class="store-price">5 credits / month</div>
                                <span class="coming-soon">Coming soon</span>
                            </div>
                            <button class="button-ghost store-button" type="button" disabled>Semi-Private Locked</button>
                        </article>
                    </div>
                </article>

                <div class="detail-grid">
                    <article class="info-card">
                        <h3>Switch Site</h3>
                        <p>What site would you like this link to be on this device? To switch back to CanLite, go to <code>/reset</code>. If you are a site owner and want your site added, DM CanLite on Discord or send an email.</p>
                        <form action="/api/switch" method="POST" class="stack" style="margin-top:18px;">
                            <label for="site-select">Choose a site</label>
                            <select id="site-select" name="site" class="styled-select">
                                <option value="https://trigonometry.texasmath.net">US5</option>
                                <option value="https://gr4ys0n.github.io">Gaming Escape</option>
                                <option value="https://securedweb.xyz">Secured Web</option>
                                <option value="https://flamepass.com">Flamepass</option>
                                <option value="https://watch.bludclart.com">Bludclart</option>
                                <option value="https://wqgqvswarit.swarit.104.36.84.31.nip.io/">Pizza Edition</option>
                            </select>
                            <div class="button-row">
                                <button type="submit" class="button">Switch</button>
                            </div>
                        </form>
                    </article>
                    <article class="info-card">
                        <h3>Session</h3>
                        <p>Use the offerwall to earn credits, then spend them in the store above. Logging out does not remove your balance.</p>
                        <div class="button-row" style="margin-top:18px;">
                            <button id="logout-button" type="button" class="button-ghost">Logout</button>
                        </div>
                    </article>
                </div>
            </div>
        </section>
    </main>

    <footer class="site-footer">
        <div class="footer-main">
            <div class="footer-links">
                <a href="/privacy">Privacy Policy</a>
                <a href="mailto:canlite24@outlook.com">Email Us</a>
                <a href="https://discord.com/invite/46gkEU5kpP" target="_blank">Join our Discord</a>
                <a href="/about">About Us</a>
            </div>
            <div class="footer-copy">&copy; <span id="year"></span> CanLite. All rights reserved.</div>
        </div>
    </footer>
</div>

<script>
    document.getElementById('year').textContent = new Date().getFullYear();

    const feedback = document.getElementById('store-feedback');
    const balanceEl = document.getElementById('credit-balance');

    for (const button of document.querySelectorAll('[data-days]')) {
        button.addEventListener('click', async () => {
            const days = Number(button.dataset.days);
            const price = Number(button.dataset.price || days);
            button.disabled = true;
            feedback.textContent = 'Processing purchase...';

            try {
                const response = await fetch('/api/store/adfree', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ days, price })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || 'Purchase failed');
                }

                balanceEl.textContent = `${data.credits} credits`;
                feedback.textContent = days >= 36500
                    ? 'Purchased lifetime ad-free access. Reloading...'
                    : `Purchased ${days} days of ad-free access. Reloading...`;
                window.setTimeout(() => window.location.reload(), 700);
            } catch (error) {
                feedback.textContent = error.message || 'Purchase failed';
            } finally {
                button.disabled = false;
            }
        });
    }

    document.getElementById('logout-button').addEventListener('click', async () => {
        await fetch('/api/logout', { method: 'POST' });
        window.location.href = '/';
    });
</script>
<script src="/games/time.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="/settings/index.js"></script>
</body>
</html>
